<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- KRI - GESTION DE PORTEFEUILLE                                 -->
    <!-- ============================================================ -->

    <record id="kri_01" model="risk.kri">
        <field name="name">Ratios règlementaires</field>
        <field name="code">KRI-01</field>
        <field name="risk_id" ref="risk_ope_01_01_01"/>
        <field name="description">Suivi des ratios règlementaires et des limites de diversification</field>
        <field name="threshold">Seuil d'alerte à déterminer</field>
        <field name="unit">%</field>
        <field name="frequency">monthly</field>
    </record>

    <record id="kri_02" model="risk.kri">
        <field name="name">Indicateurs de Liquidité du Marché</field>
        <field name="code">KRI-02</field>
        <field name="risk_id" ref="risk_ope_01_02_01"/>
        <field name="description">Fréquence des transactions journalières sur une période donnée (ex. 30 jours). Plus le volume est faible, plus le risque de blocage est élevé.</field>
        <field name="threshold">Baisse de 30% du volume</field>
        <field name="unit">Volume/jour</field>
        <field name="frequency">daily</field>
    </record>

    <record id="kri_03" model="risk.kri">
        <field name="name">Notation de crédit des émetteurs</field>
        <field name="code">KRI-03</field>
        <field name="risk_id" ref="risk_ope_01_03_01"/>
        <field name="description">Suivi des notations des agences (Moody's, S&amp;P, Fitch)</field>
        <field name="threshold">Dégradation de la note</field>
        <field name="unit">Note</field>
        <field name="frequency">monthly</field>
    </record>

    <record id="kri_04" model="risk.kri">
        <field name="name">Taux de refus des propositions d'investissement</field>
        <field name="code">KRI-04</field>
        <field name="risk_id" ref="risk_ope_01_05_01"/>
        <field name="description">Pourcentage des propositions d'investissement refusées par le comité</field>
        <field name="threshold">A définir</field>
        <field name="unit">%</field>
        <field name="frequency">monthly</field>
    </record>

    <record id="kri_05" model="risk.kri">
        <field name="name">Pourcentage de négociations non conformes</field>
        <field name="code">KRI-05</field>
        <field name="risk_id" ref="risk_ope_01_06_01"/>
        <field name="description">Pourcentage des négociations ne respectant pas les règles internes (seuil de prix)</field>
        <field name="threshold">A définir</field>
        <field name="unit">%</field>
        <field name="frequency">monthly</field>
    </record>

    <!-- ============================================================ -->
    <!-- KRI - BACK OFFICE                                             -->
    <!-- ============================================================ -->

    <record id="kri_06" model="risk.kri">
        <field name="name">Nombre de recalculs de VL</field>
        <field name="code">KRI-06</field>
        <field name="risk_id" ref="risk_ope_03_01_01"/>
        <field name="description">Nombre de recalculs de VL avant validation (Identifier les recalculs répétés qui signalent des problèmes de saisie ou de méthodologie)</field>
        <field name="threshold">Seuil d'alerte à mettre en place</field>
        <field name="unit">Nombre</field>
        <field name="frequency">daily</field>
    </record>

    <record id="kri_07" model="risk.kri">
        <field name="name">Fréquence des retards dans le calcul de la VL</field>
        <field name="code">KRI-07</field>
        <field name="risk_id" ref="risk_ope_03_01_01"/>
        <field name="description">La fréquence des retards (mensuel) dans le calcul de la VL</field>
        <field name="threshold">Seuil critique à mettre en place</field>
        <field name="unit">Nombre/mois</field>
        <field name="frequency">monthly</field>
    </record>

    <record id="kri_08" model="risk.kri">
        <field name="name">Occurrence de défaillance du système</field>
        <field name="code">KRI-08</field>
        <field name="risk_id" ref="risk_ope_03_02_01"/>
        <field name="description">Nombre d'occurrence de la défaillance du système (bugs bloquants, indisponibilité de la VL)</field>
        <field name="threshold">Maximum une fois par mois</field>
        <field name="unit">Nombre/mois</field>
        <field name="frequency">monthly</field>
    </record>

    <!-- ============================================================ -->
    <!-- KRI - RÉCONCILIATION DES COMPTES                              -->
    <!-- ============================================================ -->

    <record id="kri_09" model="risk.kri">
        <field name="name">Montant total des écarts en % de l'AUM</field>
        <field name="code">KRI-09</field>
        <field name="risk_id" ref="risk_ope_05_01_01"/>
        <field name="description">Valeur totale des écarts espèces ou titres / AUM × 100</field>
        <field name="threshold">Seuil de tolérance à définir</field>
        <field name="unit">%</field>
        <field name="frequency">monthly</field>
    </record>

    <!-- ============================================================ -->
    <!-- KRI - SOUSCRIPTION/RACHAT                                     -->
    <!-- ============================================================ -->

    <record id="kri_10" model="risk.kri">
        <field name="name">Seuil de liquidité des Fonds</field>
        <field name="code">KRI-10</field>
        <field name="risk_id" ref="risk_ope_08_01_01"/>
        <field name="description">Seuil de liquidité minimum requis pour chaque Fonds</field>
        <field name="threshold">ECG : 10%, ECO : 10%, PAT : 10%, ECL : 20%, GOORGOORLU : 20%</field>
        <field name="unit">%</field>
        <field name="frequency">daily</field>
    </record>

    <!-- ============================================================ -->
    <!-- KRI - GESTION CLIENTÈLE                                       -->
    <!-- ============================================================ -->

    <record id="kri_11" model="risk.kri">
        <field name="name">Dossiers clients incomplets</field>
        <field name="code">KRI-11</field>
        <field name="risk_id" ref="risk_ope_13_01_01"/>
        <field name="description">Dossiers clients incomplets ou erronés</field>
        <field name="threshold">Seuil d'alerte à déterminer</field>
        <field name="unit">Nombre</field>
        <field name="frequency">monthly</field>
    </record>

    <record id="kri_12" model="risk.kri">
        <field name="name">Taux de transformation des opportunités</field>
        <field name="code">KRI-12</field>
        <field name="risk_id" ref="risk_ope_14_01_01"/>
        <field name="description">Nombre de souscriptions conclues / Nombre d'opportunités créées</field>
        <field name="threshold">Seuil d'alerte à déterminer</field>
        <field name="unit">%</field>
        <field name="frequency">monthly</field>
    </record>

    <!-- ============================================================ -->
    <!-- KRI - CONTRÔLE INTERNE                                        -->
    <!-- ============================================================ -->

    <record id="kri_13" model="risk.kri">
        <field name="name">Taux d'erreurs détectées lors des audits</field>
        <field name="code">KRI-13</field>
        <field name="risk_id" ref="risk_ope_20_01_01"/>
        <field name="description">Nombre de dossiers avec anomalies après un contrôle de deuxième niveau</field>
        <field name="threshold">Seuil à déterminer</field>
        <field name="unit">%</field>
        <field name="frequency">quarterly</field>
    </record>

    <!-- ============================================================ -->
    <!-- KRI - SYSTÈME D'INFORMATION                                   -->
    <!-- ============================================================ -->

    <record id="kri_14" model="risk.kri">
        <field name="name">Taux d'échec des sauvegardes</field>
        <field name="code">KRI-14</field>
        <field name="risk_id" ref="risk_sup_14_01_01"/>
        <field name="description">Vérifie si les sauvegardes sont bien exécutées et exploitables</field>
        <field name="threshold">Seuil d'alerte à déterminer</field>
        <field name="unit">%</field>
        <field name="frequency">monthly</field>
    </record>

    <record id="kri_15" model="risk.kri">
        <field name="name">Temps moyen de récupération des données</field>
        <field name="code">KRI-15</field>
        <field name="risk_id" ref="risk_sup_14_01_01"/>
        <field name="description">Temps moyen de récupération des données après un incident (en heures/jours)</field>
        <field name="threshold">Seuil d'alerte à déterminer</field>
        <field name="unit">Heures</field>
        <field name="frequency">monthly</field>
    </record>

    <!-- ============================================================ -->
    <!-- KRI - GOUVERNANCE                                             -->
    <!-- ============================================================ -->

    <record id="kri_16" model="risk.kri">
        <field name="name">Taux de conformité profil-client / allocation</field>
        <field name="code">KRI-16</field>
        <field name="risk_id" ref="risk_pil_01_01_01"/>
        <field name="description">Taux de conformité entre le profil de risque du client et l'allocation réelle des fonds</field>
        <field name="threshold">Seuil à déterminer</field>
        <field name="unit">%</field>
        <field name="frequency">monthly</field>
    </record>

    <record id="kri_17" model="risk.kri">
        <field name="name">Existence du Comité des Risques</field>
        <field name="code">KRI-17</field>
        <field name="risk_id" ref="risk_pil_01_02_01"/>
        <field name="description">Vérification de l'existence du Comité des Risques</field>
        <field name="threshold">Oui/Non</field>
        <field name="unit">Booléen</field>
        <field name="frequency">quarterly</field>
    </record>

</odoo>