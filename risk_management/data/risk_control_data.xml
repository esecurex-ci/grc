        <field name="control_type">detective</field>
        <field name="effectiveness">high</field>
        <field name="frequency">monthly</field>

    </record>

    <record id="control_cf_02" model="risk.control">
        <field name="name">Vérification des factures fournisseurs</field>
        <field name="code">CTRL-CF-02</field>
        <field name="description">Le contrôle interne vérifie le respect de la procédure d'achat et appose son visa avant l'archivage des factures</field>
        <field name="control_type">detective</field>
        <field name="effectiveness">high</field>
        <field name="frequency">daily</field>

    </record>

    <record id="control_cf_03" model="risk.control">
