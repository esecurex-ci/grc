    <!-- ============================================================ -->

    <record id="control_rh_01" model="risk.control">
        <field name="name">Vérification des bulletins de salaire</field>
        <field name="code">CTRL-RH-01</field>
        <field name="description">Vérification des bulletins de salaire par la DGA avant validation et paiement</field>
        <field name="control_type">detective</field>
        <field name="effectiveness">medium</field>
        <field name="frequency">monthly</field>

    </record>

    <record id="control_rh_02" model="risk.control">
        <field name="name">Déclaration CNPS des employés</field>
        <field name="code">CTRL-RH-02</field>
        <field name="description">La DGA s'assure que les employés ont été déclarés à la CNPS</field>
        <field name="control_type">preventive</field>
        <field name="effectiveness">medium</field>
        <field name="frequency">monthly</field>

    </record>

    <record id="control_rh_03" model="risk.control">
        <field name="name">Validation des demandes de congés</field>
        <field name="code">CTRL-RH-03</field>
