        <field name="control_type">detective</field>
        <field name="effectiveness">medium</field>
        <field name="frequency">annual</field>

    </record>

    <record id="control_cf_05" model="risk.control">
        <field name="name">Contrôle de la caisse</field>
        <field name="code">CTRL-CF-05</field>
