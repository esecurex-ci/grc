<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- 1. PROCESSUS DE PILOTAGE (Pilotage)                          -->
    <!-- ============================================================ -->

    <record id="process_pilotage_01" model="risk.process">
        <field name="name">Gouvernance et stratégie</field>
        <field name="code">PIL-01</field>
        <field name="category">pilotage</field>
        <field name="count_risk">3</field>
        <field name="description">Élaboration de la stratégie de gestion des Fonds, mise en place des organes de gouvernance (Conseil d'Administration, Comité d'Investissement, Comité des Risques) et dispositif de contrôle.</field>
    </record>

    <record id="process_pilotage_02" model="risk.process">
        <field name="name">Élaboration budgétaire</field>
        <field name="code">PIL-02</field>
        <field name="category">pilotage</field>
        <field name="count_risk">2</field>
        <field name="description">Établissement du budget, planification des ressources, transmission et validation par la DGA et le Conseil d'Administration.</field>
    </record>

    <record id="process_pilotage_03" model="risk.process">
        <field name="name">Gestion du budget</field>
        <field name="code">PIL-03</field>
        <field name="category">pilotage</field>
        <field name="count_risk">2</field>
        <field name="description">Validation, arbitrage budgétaire, exécution et suivi budgétaire trimestriel.</field>
    </record>

    <record id="process_pilotage_04" model="risk.process">
        <field name="name">Rédaction de la Politique d'investissement</field>
        <field name="code">PIL-04</field>
        <field name="category">pilotage</field>
        <field name="count_risk">2</field>
        <field name="description">Rédaction et actualisation de la politique d'investissement, définition des objectifs de performance des Fonds.</field>
    </record>

    <record id="process_pilotage_05" model="risk.process">
        <field name="name">Éthique et déontologie</field>
        <field name="code">PIL-05</field>
        <field name="category">pilotage</field>
        <field name="count_risk">2</field>
        <field name="description">Gestion de l'éthique et de la déontologie, prévention des conflits d'intérêts, protection du secret professionnel.</field>
    </record>

    <record id="process_pilotage_06" model="risk.process">
        <field name="name">Gestion des conflits d'intérêts</field>
        <field name="code">PIL-06</field>
        <field name="category">pilotage</field>
        <field name="count_risk">2</field>
        <field name="description">Établissement et actualisation de la politique et du registre des conflits d'intérêts.</field>
    </record>

    <record id="process_pilotage_07" model="risk.process">
        <field name="name">Système de management des risques</field>
        <field name="code">PIL-07</field>
        <field name="category">pilotage</field>
        <field name="count_risk">5</field>
        <field name="description">Établissement et mise à jour de la cartographie des risques, politiques de gestion des risques, tests de résistance, manuels de procédure et rapports de risques.</field>
    </record>

    <record id="process_pilotage_08" model="risk.process">
        <field name="name">Surveillance des ratios prudentiels</field>
        <field name="code">PIL-08</field>
        <field name="category">pilotage</field>
        <field name="count_risk">1</field>
        <field name="description">Suivi des ratios réglementaires et internes (concentration, allocation, liquidité).</field>
    </record>

    <record id="process_pilotage_09" model="risk.process">
        <field name="name">Suivi de la stratégie d'investissement</field>
        <field name="code">PIL-09</field>
        <field name="category">pilotage</field>
        <field name="count_risk">3</field>
        <field name="description">Comparaison de la gestion des Fonds avec les orientations stratégiques, suivi des objectifs annuels, rédaction des PV du comité d'investissement.</field>
    </record>

    <record id="process_pilotage_10" model="risk.process">
        <field name="name">Établissement des rapports de contrôle interne</field>
        <field name="code">PIL-10</field>
        <field name="category">pilotage</field>
        <field name="count_risk">3</field>
        <field name="description">Établissement des rapports annuels d'activité, rapports de contrôle interne, mise à jour des DICI et prospectus, transmission à l'AMF-UMOA.</field>
    </record>

    <!-- ============================================================ -->
    <!-- 2. PROCESSUS OPÉRATIONNELS (Opérationnel)                    -->
    <!-- ============================================================ -->

    <!-- Gestion de portefeuille -->
    <record id="process_operational_01" model="risk.process">
        <field name="name">Proposition d'investissement</field>
        <field name="code">OPE-01</field>
        <field name="category">operational</field>
        <field name="count_risk">6</field>
        <field name="description">Mise en œuvre de la stratégie d'investissement, recherche d'acheteurs, propositions d'opportunités d'investissement (obligataires et actions), négociation avec les contreparties.</field>
    </record>

    <record id="process_operational_02" model="risk.process">
        <field name="name">Création de nouveaux OPCVM</field>
        <field name="code">OPE-02</field>
        <field name="category">operational</field>
        <field name="count_risk">5</field>
        <field name="description">Définition du profil du Fonds, établissement des projections financières, paramétrage dans ATLANTIS SGO, support à l'élaboration des documents commerciaux.</field>
    </record>

    <!-- Back Office -->
    <record id="process_operational_03" model="risk.process">
        <field name="name">Calcul et validation de la VL</field>
        <field name="code">OPE-03</field>
        <field name="category">operational</field>
        <field name="count_risk">4</field>
        <field name="description">Saisie des informations, lancement du calcul de la VL, transmission et validation de la matrice, transmission à la BRVM.</field>
    </record>

    <record id="process_operational_04" model="risk.process">
        <field name="name">Réconciliation des comptes</field>
        <field name="code">OPE-04</field>
        <field name="category">operational</field>
        <field name="count_risk">4</field>
        <field name="description">Réception des relevés de comptes titres, espèces et courant, vérification de la concordance, enregistrement des régularisations.</field>
    </record>

    <record id="process_operational_05" model="risk.process">
        <field name="name">Traitement des opérations DAT</field>
        <field name="code">OPE-05</field>
        <field name="category">operational</field>
        <field name="count_risk">4</field>
        <field name="description">Établissement et transmission des ordres de virement, comptabilisation des opérations DAT, suivi des intérêts.</field>
    </record>

    <record id="process_operational_06" model="risk.process">
        <field name="name">Traitement des opérations sur titres</field>
        <field name="code">OPE-06</field>
        <field name="category">operational</field>
        <field name="count_risk">5</field>
        <field name="description">Établissement et transmission des ordres d'achat/vente, vérification des avis d'opéré, comptabilisation des opérations.</field>
    </record>

    <record id="process_operational_07" model="risk.process">
        <field name="name">Traitement des opérations de souscription/rachat</field>
        <field name="code">OPE-07</field>
        <field name="category">operational</field>
        <field name="count_risk">5</field>
        <field name="description">Vérification du cash disponible, établissement des ordres de paiement, comptabilisation des opérations de souscription et rachat.</field>
    </record>

    <record id="process_operational_08" model="risk.process">
        <field name="name">Valorisation des actifs</field>
        <field name="code">OPE-08</field>
        <field name="category">operational</field>
        <field name="count_risk">2</field>
        <field name="description">Mise à jour des cours des titres cotés, évaluation des titres non cotés.</field>
    </record>

    <record id="process_operational_09" model="risk.process">
        <field name="name">Traitement des frais de gestion</field>
        <field name="code">OPE-09</field>
        <field name="category">operational</field>
        <field name="count_risk">5</field>
        <field name="description">Traitement des frais de gestion (DDG, commission DC/BR), commission actif sous gestion, redevance annuelle, droit d'entrée et de sortie.</field>
    </record>

    <record id="process_operational_10" model="risk.process">
        <field name="name">Suivi des coupons à recevoir</field>
        <field name="code">OPE-10</field>
        <field name="category">operational</field>
        <field name="count_risk">2</field>
        <field name="description">Suivi du paiement des coupons et amortissements par les émetteurs, réception des avis de crédit.</field>
    </record>

    <record id="process_operational_11" model="risk.process">
        <field name="name">Établissement des rapports réglementaires</field>
        <field name="code">OPE-11</field>
        <field name="category">operational</field>
        <field name="count_risk">3</field>
        <field name="description">Établissement des états financiers des Fonds, états de composition des actifs, rapports réglementaires, constitution des fonds de dossier.</field>
    </record>

    <!-- Clientèle -->
    <record id="process_operational_12" model="risk.process">
        <field name="name">Entrées en relation</field>
        <field name="code">OPE-12</field>
        <field name="category">operational</field>
        <field name="count_risk">5</field>
        <field name="description">Collecte des informations KYC, évaluation des clients, création de compte, enregistrement et archivage des dossiers clients.</field>
    </record>

    <record id="process_operational_13" model="risk.process">
        <field name="name">Processus de vente</field>
        <field name="code">OPE-13</field>
        <field name="category">operational</field>
        <field name="count_risk">4</field>
        <field name="description">Prospection, suivi clientèle, fidélisation, gestion des performances commerciales.</field>
    </record>

    <record id="process_operational_14" model="risk.process">
        <field name="name">Traitement des souscriptions/rachats (clientèle)</field>
        <field name="code">OPE-14</field>
        <field name="category">operational</field>
        <field name="count_risk">5</field>
        <field name="description">Réception et vérification des documents clients, enregistrement des opérations, transmission des bulletins, archivage.</field>
    </record>

    <record id="process_operational_15" model="risk.process">
        <field name="name">Gestion des réclamations clients</field>
        <field name="code">OPE-15</field>
        <field name="category">operational</field>
        <field name="count_risk">3</field>
        <field name="description">Réception et traitement des réclamations, enregistrement et archivage des fiches de réclamation.</field>
    </record>

    <record id="process_operational_16" model="risk.process">
        <field name="name">Reporting client</field>
        <field name="code">OPE-16</field>
        <field name="category">operational</field>
        <field name="count_risk">1</field>
        <field name="description">Transmission des rapports de gestion des Fonds aux clients.</field>
    </record>

    <record id="process_operational_17" model="risk.process">
        <field name="name">Rédaction des rapports semestriels</field>
        <field name="code">OPE-17</field>
        <field name="category">operational</field>
        <field name="count_risk">1</field>
        <field name="description">Rédaction des rapports semestriels d'activité commerciale.</field>
    </record>

    <record id="process_operational_18" model="risk.process">
        <field name="name">Support marketing</field>
        <field name="code">OPE-18</field>
        <field name="category">operational</field>
        <field name="count_risk">2</field>
        <field name="description">Rédaction des documents de présentation des Fonds, support à l'élaboration des rapports de gestion.</field>
    </record>

    <!-- Contrôle interne & Conformité -->
    <record id="process_operational_19" model="risk.process">
        <field name="name">Contrôle des dossiers clients</field>
        <field name="code">OPE-19</field>
        <field name="category">operational</field>
        <field name="count_risk">3</field>
        <field name="description">Vérification de l'exhaustivité et de la conformité des dossiers clients, validation des ouvertures de compte, contrôle de la note d'évaluation des investisseurs.</field>
    </record>

    <record id="process_operational_20" model="risk.process">
        <field name="name">Surveillance particulière des opérations</field>
        <field name="code">OPE-20</field>
        <field name="category">operational</field>
        <field name="count_risk">5</field>
        <field name="description">Suivi des opérations ≥ 50M FCFA et ≥ 10M FCFA inhabituelles, mise à jour des listes GAFI, suivi des opérations électroniques et occasionnelles.</field>
    </record>

    <record id="process_operational_21" model="risk.process">
        <field name="name">Suivi des opérations électroniques</field>
        <field name="code">OPE-21</field>
        <field name="category">operational</field>
        <field name="count_risk">2</field>
        <field name="description">Surveillance des transactions électroniques, détection des opérations suspectes, déclaration à la CENTIF.</field>
    </record>

    <record id="process_operational_22" model="risk.process">
        <field name="name">Audit interne</field>
        <field name="code">OPE-22</field>
        <field name="category">operational</field>
        <field name="count_risk">2</field>
        <field name="description">Élaboration du plan d'audit interne, mise en œuvre des activités du plan d'audit.</field>
    </record>

    <record id="process_operational_23" model="risk.process">
        <field name="name">Gestion des incidents informatiques</field>
        <field name="code">OPE-23</field>
        <field name="category">operational</field>
        <field name="count_risk">1</field>
        <field name="description">Rédaction et transmission des rapports sur la gestion des incidents informatiques.</field>
    </record>

    <record id="process_operational_24" model="risk.process">
        <field name="name">Gestion du site web</field>
        <field name="code">OPE-24</field>
        <field name="category">operational</field>
        <field name="count_risk">2</field>
        <field name="description">Animation du site web, publication d'informations conformes à la réglementation AMF-UMOA.</field>
    </record>

    <!-- ============================================================ -->
