<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="risk_management.process_dashboard" owl="1">
        <div class="process-dashboard-container">

            <!-- ========================================= -->
            <!-- CHARGEMENT                               -->
            <!-- ========================================= -->
            <div t-if="state.loading" style="text-align:center;padding:50px;color:#6c757d;">
                <i class="fa fa-spinner fa-spin fa-3x" style="color:#1a237e;"></i>
                <p style="margin-top:15px;">Chargement du tableau de bord...</p>
            </div>

            <div t-else="">

                <!-- ========================================= -->
                <!-- HEADER                                    -->
                <!-- ========================================= -->
                <div class="dashboard-header">
                    <h2>📋 Tableau de Bord des Processus Métiers</h2>
                    <div class="dashboard-date">
                        <i class="fa fa-calendar" title="Date de mise à jour"/>
                        Généré le <t t-esc="new Date().toLocaleDateString('fr-FR')"/>
                    </div>
                </div>

                <!-- ========================================= -->
                <!-- KPI CARDS                                -->
                <!-- ========================================= -->
                <div class="row g-2 mb-4">
                    <div class="col-2">
                        <div class="kpi-card" t-on-click="openAllProcesses">
                            <div class="kpi-label">Total Processus</div>
                            <div class="kpi-value"><t t-esc="state.totalProcesses"/></div>
                        </div>
                    </div>
                    <div class="col-2">
                        <div class="kpi-card kpi-critical" t-on-click="openCriticalProcesses">
                            <div class="kpi-label">🔴 Critiques</div>
                            <div class="kpi-value"><t t-esc="state.critical"/></div>
                        </div>
                    </div>
                    <div class="col-2">
                        <div class="kpi-card kpi-high">
                            <div class="kpi-label">🟠 Élevés</div>
                            <div class="kpi-value"><t t-esc="state.high"/></div>
                        </div>
                    </div>
                    <div class="col-2">
                        <div class="kpi-card kpi-medium">
                            <div class="kpi-label">🟡 Moyens</div>
                            <div class="kpi-value"><t t-esc="state.medium"/></div>
                        </div>
                    </div>
                    <div class="col-2">
                        <div class="kpi-card kpi-low">
                            <div class="kpi-label">🟢 Faibles</div>
                            <div class="kpi-value"><t t-esc="state.low"/></div>
                        </div>
                    </div>
                    <div class="col-2">
                        <div class="kpi-card kpi-avg" t-on-click="openCriticalProcesses">
                            <div class="kpi-label">🔴 Taux critique</div>
                            <div class="kpi-value">
                                <t t-esc="state.critical"/> / <t t-esc="state.totalProcesses"/>
                            </div>
                            <div class="kpi-progress">
                                <div class="progress-track">
                                    <div class="progress-fill" t-attf-style="width:#{(state.critical / Math.max(state.totalProcesses, 1)) * 100}%;background:#dc3545;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ========================================= -->
                <!-- DONUT CHARTS (Répartition)               -->
                <!-- ========================================= -->
                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <div class="chart-card">
                            <h5 class="chart-title">📊 Répartition des Processus par Niveau de Risque</h5>
                            <div t-out="renderDonutChart(state.riskDistribution, state.totalProcesses)"/>
                        </div>
                    </div>
                </div>

                <!-- ========================================= -->
                <!-- MATRICE DES PROCESSUS PAR CATÉGORIE     -->
                <!-- ========================================= -->
                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <div class="chart-card">
                            <h5 class="chart-title">🔥 Matrice des Processus par Catégorie</h5>
                            <div class="table-responsive">
                                <table class="matrix-table">
                                    <thead>
                                        <tr>
                                            <th>Catégorie ↓</th>
                                            <th>🔴 Critiques</th>
                                            <th>🟠 Élevés</th>
                                            <th>🟡 Moyens</th>
                                            <th>🟢 Faibles</th>
                                            <th>Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="Object.keys(state.matrix)" t-as="cat" t-key="cat">
                                            <td><strong><t t-esc="formatCategory(cat)"/></strong></td>
                                            <td t-attf-class="cell-{{state.matrix[cat].critical > 0 ? 'danger' : 'empty'}}">
                                                <t t-esc="state.matrix[cat].critical || 0"/>
                                            </td>
                                            <td t-attf-class="cell-{{state.matrix[cat].high > 0 ? 'warning' : 'empty'}}">
                                                <t t-esc="state.matrix[cat].high || 0"/>
                                            </td>
                                            <td t-attf-class="cell-{{state.matrix[cat].medium > 0 ? 'info' : 'empty'}}">
                                                <t t-esc="state.matrix[cat].medium || 0"/>
                                            </td>
                                            <td t-attf-class="cell-{{state.matrix[cat].low > 0 ? 'success' : 'empty'}}">
                                                <t t-esc="state.matrix[cat].low || 0"/>
                                            </td>
                                            <td><strong><t t-esc="state.matrix[cat].total || 0"/></strong></td>
                                        </tr>
                                        <tr style="font-weight:bold;background:#f8f9fa;">
                                            <td>Total</td>
                                            <td><t t-esc="state.critical"/></td>
                                            <td><t t-esc="state.high"/></td>
                                            <td><t t-esc="state.medium"/></td>
                                            <td><t t-esc="state.low"/></td>
                                            <td><t t-esc="state.totalProcesses"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ========================================= -->
                <!-- DEUX COLONNES : CRITIQUES + TOP 5        -->
                <!-- ========================================= -->
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="chart-card">
                            <h5 class="chart-title">🎯 Processus Critiques</h5>
                            <div t-if="state.criticalProcesses.length > 0">
                                <div class="risk-item" t-foreach="state.criticalProcesses" t-as="process" t-key="process.id">
                                    <div class="process-item" t-on-click="() => openProcessById(process.id)">
                                        <div class="process-info">
                                            <span class="risk-level-badge critical">🔴 Critique</span>
                                            <span class="process-name"><t t-esc="process.name"/></span>
                                            <span class="process-code"><t t-esc="process.code"/></span>
                                        </div>
                                        <div class="process-stats">
                                            <span class="badge badge-danger"><t t-esc="process.count"/> risques</span>
                                            <span class="process-owner"><i class="fa fa-user" title="Propriétaire"/> <t t-esc="process.owner"/></span>
                                        </div>
                                    </div>
                                </div>
                                <a href="#" class="view-all-link" t-on-click.prevent="openCriticalProcesses">
                                    Voir tous les processus critiques →
                                </a>
                            </div>
                            <div t-else="" style="text-align:center;padding:20px;color:#28a745;">
                                ✅ Aucun processus critique
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="chart-card">
                            <h5 class="chart-title">📋 Top 5 Processus à risque</h5>
                            <div class="risk-item" t-foreach="state.topProcesses" t-as="process" t-key="process.id">
                                <div class="process-item" t-on-click="() => openProcessById(process.id)">
                                    <div class="process-info">
                                        <span class="rank-badge">#<t t-esc="process_index + 1"/></span>
                                        <span class="risk-level-badge" t-attf-class="risk-level-badge #{getLevelBadge(process.level)}">
                                            <t t-esc="getLevelBadge(process.level)"/>
                                        </span>
                                        <span class="process-name"><t t-esc="process.name"/></span>
                                        <span class="process-code"><t t-esc="process.code"/></span>
                                    </div>
                                    <div class="process-stats">
                                        <span class="badge badge-secondary"><t t-esc="process.count"/> risques</span>
                                        <span class="process-owner"><i class="fa fa-user" title="Propriétaire"/> <t t-esc="process.owner"/></span>
                                    </div>
                                </div>
                            </div>
                            <a href="#" class="view-all-link" t-on-click.prevent="openAllProcesses">
                                Voir tous les processus →
                            </a>
                        </div>
                    </div>
                </div>

                <!-- ========================================= -->
                <!-- BARRES HORIZONTALES                       -->
                <!-- ========================================= -->
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="chart-card">
                            <h5 class="chart-title">📊 Distribution des Niveaux de Risque</h5>
                            <div class="bar-chart">
                                <div class="bar-row" t-foreach="state.riskDistribution" t-as="item" t-key="item.label">
                                    <span class="bar-label"><t t-esc="item.label"/></span>
                                    <div class="bar-track">
                                        <div class="bar-fill" t-attf-style="width:#{(item.value / getMaxDistribution()) * 100}%;background:#{item.color};">
                                            <span class="bar-value-label"><t t-esc="item.value"/></span>
                                        </div>
                                    </div>
                                    <span class="bar-value"><t t-esc="item.value"/></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="chart-card">
                            <h5 class="chart-title">📈 Répartition par Catégorie</h5>
                            <div class="category-bars">
                                <div class="category-row" t-foreach="Object.entries(state.categoryStats)" t-as="item" t-key="item[0]">
                                    <span class="cat-label"><t t-esc="item[0]"/></span>
                                    <div class="cat-track">
                                        <div class="cat-fill" t-attf-style="width:#{(item[1] / getCategoryMax()) * 100}%;background:#1a237e;"></div>
                                    </div>
                                    <span class="cat-value"><t t-esc="item[1]"/></span>
                                    <span class="cat-percent" t-if="state.totalProcesses > 0">
                                        (<t t-esc="Math.round((item[1] / state.totalProcesses) * 100)"/>%)
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ========================================= -->
                <!-- PROCESSUS SANS RISQUE                     -->
                <!-- ========================================= -->
                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <div class="chart-card">
                            <h5 class="chart-title">⬜ Processus sans risque identifié</h5>
                            <div t-if="state.processesWithoutRisk.length > 0">
                                <div class="no-risk-grid">
                                    <div class="no-risk-item" t-foreach="state.processesWithoutRisk" t-as="process" t-key="process.id">
                                        <span class="no-risk-code"><t t-esc="process.code"/></span>
                                        <span class="no-risk-name"><t t-esc="process.name"/></span>
                                        <span class="badge badge-secondary"><t t-esc="process.category"/></span>
                                    </div>
                                </div>
                            </div>
                            <div t-else="" style="text-align:center;padding:20px;color:#28a745;">
                                ✅ Tous les processus ont des risques identifiés
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ========================================= -->
                <!-- RAPPORT NARRATIF                         -->
                <!-- ========================================= -->
                <div class="row g-3">
                    <div class="col-12">
                        <div class="chart-card narrative-card">
                            <h5 class="chart-title">📝 Rapport Narratif - Principaux changements</h5>
                            <div t-foreach="state.narratives" t-as="item" t-key="item.icon">
                                <div class="narrative-item">
                                    <span class="narr-icon"><t t-esc="item.icon"/></span>
                                    <span class="narr-text"><t t-esc="item.text"/></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ========================================= -->
                <!-- LÉGENDE                                  -->
                <!-- ========================================= -->
                <div class="row mt-4">
                    <div class="col-12">
                        <div class="dashboard-legend">
                            <span><span class="legend-color" style="background:#dc3545;"></span> Critique</span>
                            <span><span class="legend-color" style="background:#fd7e14;"></span> Élevé</span>
                            <span><span class="legend-color" style="background:#ffc107;"></span> Moyen</span>
                            <span><span class="legend-color" style="background:#28a745;"></span> Faible</span>
                            <span class="legend-separator">|</span>
                            <span><i class="fa fa-user" title="Propriétaire"></i> Propriétaire</span>
                            <span><i class="fa fa-exclamation-triangle" title="Risques"></i> Nombre de risques</span>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </t>

</templates>