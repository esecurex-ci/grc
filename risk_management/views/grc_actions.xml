<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================== -->
    <!-- DASHBOARD -->
    <!-- ===================================================== -->
    <record id="action_grc_dashboard_client" model="ir.actions.client">
        <field name="name">GRC Executive Dashboard</field>
        <field name="tag">grc_dashboard</field>
    </record>

    <record id="action_risk_executive_dashboard_snapshot" model="ir.actions.act_window">
        <field name="name">Executive Dashboard</field>
        <field name="res_model">risk.executive.dashboard.snapshot</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_risk_grc_score" model="ir.actions.act_window">
        <field name="name">GRC Scores</field>
        <field name="res_model">risk.grc.score</field>
        <field name="view_mode">list,form,graph,pivot</field>
    </record>

    <record id="action_risk_grc_history" model="ir.actions.act_window">
        <field name="name">GRC History</field>
        <field name="res_model">risk.grc.history</field>
        <field name="view_mode">list,form,graph,pivot</field>

    </record>

    <!-- ===================================================== -->
    <!-- RISK MANAGEMENT -->
    <!-- ===================================================== -->

    <!-- ACTION - TABLEAU DE BORD -->
    <record id="action_risk_dashboard" model="ir.actions.act_window">
        <field name="name">📊 Tableau de bord</field>
        <field name="res_model">risk.risk</field>
        <field name="view_mode">kanban,graph</field>
        <field name="view_id" ref="view_risk_dashboard_kanban"/>
        <field name="search_view_id" ref="view_risk_cartography_search"/>
    </record>

    <record id="action_risk_risk" model="ir.actions.act_window">
        <field name="name">Risk Register</field>
        <field name="res_model">risk.risk</field>
        <field name="context">{}</field>
        <field name="view_mode">list,form,kanban,graph</field>
        <field name="view_id" ref="view_risk_cartography_list"/>
        <field name="view_id" ref="view_risk_form_new"/>
    </record>

    <record id="action_risk_assessment" model="ir.actions.act_window">
        <field name="name">Risk Assessments</field>
        <field name="res_model">risk.assessment</field>
        <field name="view_mode">list,form,graph,pivot</field>
    </record>

    <record id="action_risk_assessment_period" model="ir.actions.act_window">
        <field name="name">Assessment Periods</field>
        <field name="res_model">risk.assessment.period</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_risk_treatment_plan" model="ir.actions.act_window">
        <field name="name">Treatment Plans</field>
        <field name="res_model">risk.treatment.plan</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- ACTION - CARTOGRAPHIE (Liste) -->
    <record id="action_risk_cartography" model="ir.actions.act_window">
        <field name="name">📋 Cartographie</field>
        <field name="res_model">risk.risk</field>
        <field name="view_mode">form,graph</field>
        <field name="view_id" ref="view_risk_cartography_heatmap"/>
        <field name="search_view_id" ref="view_risk_cartography_search"/>
        <field name="res_id">1</field>
        <field name="context">{
            'form_view_ref': 'risk_management.view_risk_cartography_heatmap',
            'create': False,
            'edit': False,
            'form_view_initial_mode': 'readonly'
            }</field>
    </record>

    <!-- ACTION - HEATMAP (Matrice visuelle) -->
    <record id="action_risk_heatmap" model="ir.actions.act_window">
        <field name="name">🔥 Heatmap</field>
        <field name="res_model">risk.risk</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_risk_cartography_heatmap"/>

        <field name="context">{
            'create': False,
            'edit': False,
            'form_view_ref': 'risk_management.view_risk_cartography_dashboard',
            'form_view_initial_mode': 'readonly'
            }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                🔥 Carte de chaleur des risques
            </p>
            <p>
                Visualisez la concentration de vos risques par niveau de criticité.
            </p>
        </field>
    </record>

