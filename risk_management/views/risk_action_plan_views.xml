<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- VUE LISTE - Plan d'action -->
    <record id="view_risk_action_plan_list" model="ir.ui.view">
        <field name="name">risk.action.plan.list</field>
        <field name="model">risk.action.plan</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'completed'"
                  decoration-info="state == 'in_progress'"
                  decoration-warning="state == 'draft'"
                  decoration-danger="state in ('cancelled')">
                <field name="code"/>
                <field name="name"/>
                <field name="owner_id"/>
                <field name="state" widget="badge"/>
                <field name="task_count"/>
                <field name="task_progress" widget="progressbar"/>
                <field name="deadline"/>
                <field name="risk_id"/>
            </list>
        </field>
    </record>

    <!-- VUE FORMULAIRE - Plan d'action -->
    <record id="view_risk_action_plan_form" model="ir.ui.view">
        <field name="name">risk.action.plan.form</field>
        <field name="model">risk.action.plan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" string="✅ Approuver" type="object"
                            class="btn-success" invisible="state != 'draft'"/>
                    <button name="action_start" string="🔄 Démarrer" type="object"
                            class="btn-primary" invisible="state != 'approved'"/>
                    <button name="action_complete" string="✅ Terminer" type="object"
                            class="btn-success" invisible="state != 'in_progress'"/>
                    <button name="action_cancel" string="❌ Annuler" type="object"
                            class="btn-danger" invisible="state in ['completed', 'cancelled']"/>
                    <button name="action_add_task" string="➕ Ajouter une tâche" type="object" class="btn-primary"/>
                    <button name="action_view_tasks" string="📋 Voir les tâches" type="object"
                            class="btn-secondary" invisible="task_count == 0"/>
                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nom du plan d'action..."/>
                        </h1>
                        <span class="oe_subtitle">
                            <field name="code" placeholder="Code"/>
                            <span class="badge badge-secondary"><field name="state" widget="badge"/></span>
                        </span>
                    </div>

                    <group>
                        <group>
                            <field name="owner_id" required="1"/>
                            <field name="approver_id"/>
                            <field name="risk_id"/>
                            <field name="incident_id"/>
                            <field name="control_id"/>
                        </group>
                        <group>
                            <field name="start_date" required="1"/>
                            <field name="deadline" required="1"/>
                            <field name="end_date"/>
                            <field name="task_count" readonly="1"/>
                            <field name="task_progress" readonly="1" widget="progressbar"/>
                            <field name="state" widget="badge"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="📝 Description">
                            <field name="description"/>
                        </page>

                        <page string="📋 Tâches">
                            <div class="alert alert-info" role="status">
                                <i class="fa fa-info-circle" title="Information"/>
                                <strong><field name="task_count"/></strong> tâche(s)
                                <span class="text-muted">- Terminées: <field name="task_completed_count"/></span>
                                <span class="text-muted">- En cours: <field name="task_in_progress_count"/></span>
                                <span class="text-muted">- Progression: <field name="task_progress"/>%</span>
                            </div>
                            <field name="task_ids" context="{'default_plan_id': id}">
                                <list decoration-success="state == 'done'"
                                      decoration-info="state == 'in_progress'"
                                      decoration-warning="state == 'review'"
                                      decoration-danger="state in ('draft', 'cancelled')">
                                    <field name="sequence" widget="handle"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="owner_id"/>
                                    <field name="priority" widget="badge"/>
                                    <field name="state" widget="badge"/>
                                    <field name="progress" widget="progressbar"/>
                                    <field name="deadline"/>
                                    <field name="is_overdue" widget="boolean" string="⏰"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

</odoo>