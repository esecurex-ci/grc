<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================= -->
    <!-- VUE LISTE - Tâches                        -->
    <!-- ========================================= -->
    <record id="view_risk_action_task_list" model="ir.ui.view">
        <field name="name">risk.action.task.list</field>
        <field name="model">risk.action.task</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'done'"
                  decoration-info="state == 'in_progress'"
                  decoration-warning="state == 'review'"
                  decoration-danger="state in ('draft', 'cancelled')">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="plan_id"/>
                <field name="owner_id"/>
                <field name="priority" widget="badge"/>
                <field name="state" widget="badge"/>
                <field name="progress" widget="progressbar"/>
                <field name="deadline"/>
                <field name="is_overdue" widget="boolean" string="⏰"/>
            </list>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- VUE FORMULAIRE - Tâche                    -->
    <!-- ========================================= -->
    <record id="view_risk_action_task_form" model="ir.ui.view">
        <field name="name">risk.action.task.form</field>
        <field name="model">risk.action.task</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" string="🔄 Démarrer" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_review" string="🔍 Soumettre à relecture" type="object"
                            class="btn-warning" invisible="state != 'in_progress'"/>
                    <button name="action_done" string="✅ Terminer" type="object"
                            class="btn-success" invisible="state not in ['in_progress', 'review']"/>
                    <button name="action_cancel" string="❌ Annuler" type="object"
                            class="btn-danger" invisible="state in ['done', 'cancelled']"/>
                    <button name="action_reset_to_draft" string="📝 Remettre à faire" type="object"
                            class="btn-secondary" invisible="state in ['draft']"/>
                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <span style="background:#1a237e;color:white;padding:2px 10px;border-radius:4px;font-size:12px;">✅ TÂCHE</span>
                            <field name="name" placeholder="Nom de la tâche..."/>
                        </h1>
                        <span class="oe_subtitle">
                            <field name="code" placeholder="Code"/>
                            <span class="badge badge-secondary"><field name="plan_id"/></span>
                            <span class="badge badge-info"><field name="priority" widget="badge"/></span>
                            <span class="badge badge-secondary"><field name="state" widget="badge"/></span>
                        </span>
                    </div>

                    <group>
                        <group>
                            <field name="plan_id" required="1"/>
                            <field name="owner_id" required="1"/>
                            <field name="deadline" required="1"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="state" widget="badge"/>
                            <field name="progress" widget="progressbar"/>
                            <field name="priority" widget="badge"/>
                            <field name="is_overdue" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="📝 Description">
                            <field name="description" placeholder="Description détaillée de la tâche..."/>
                            <field name="result" placeholder="Résultat de la tâche..."/>
                        </page>
                    </notebook>
                </sheet>

                <chatter>
                    <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- VUE RECHERCHE - Tâches                    -->
    <!-- ========================================= -->
    <record id="view_risk_action_task_search" model="ir.ui.view">
        <field name="name">risk.action.task.search</field>
        <field name="model">risk.action.task</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="plan_id"/>
                <field name="owner_id"/>

                <filter name="state_draft" string="À faire" domain="[('state', '=', 'draft')]"/>
                <filter name="state_in_progress" string="En cours" domain="[('state', '=', 'in_progress')]"/>
                <filter name="state_review" string="En relecture" domain="[('state', '=', 'review')]"/>
                <filter name="state_done" string="Terminé" domain="[('state', '=', 'done')]"/>

                <separator/>

                <filter name="priority_high" string="Haute priorité" domain="[('priority', 'in', ['high', 'critical'])]"/>
                <filter name="overdue" string="En retard" domain="[('is_overdue', '=', True)]"/>
                <filter name="my_tasks" string="Mes tâches" domain="[('owner_id.user_id', '=', uid)]"/>
            </search>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- VUE KANBAN - Tâches (corrigée)            -->
    <!-- ========================================= -->
    <record id="view_risk_action_task_kanban" model="ir.ui.view">
        <field name="name">risk.action.task.kanban</field>
        <field name="model">risk.action.task</field>
        <field name="arch" type="xml">
            <kanban>
                <!-- ✅ TOUS LES CHAMPS UTILISÉS DOIVENT ÊTRE DÉCLARÉS ICI -->
                <field name="name"/>
                <field name="code"/>
                <field name="state"/>
                <field name="priority"/>
                <field name="owner_id"/>
                <field name="deadline"/>
                <field name="progress"/>
                <field name="is_overdue"/>
                <field name="plan_id"/>

                <templates>
                    <!-- ✅ LE NOM DU TEMPLATE DOIT ÊTRE "kanban-box" -->
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <span class="o_kanban_image_size" style="font-size:24px;">
                                    <t t-if="record.priority.raw_value == 'critical'">🔴</t>
                                    <t t-elif="record.priority.raw_value == 'high'">🟠</t>
                                    <t t-elif="record.priority.raw_value == 'medium'">🟡</t>
                                    <t t-else="">🟢</t>
                                </span>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="code"/> - <field name="name"/>
                                </strong>
                                <div class="text-muted">
                                    <field name="plan_id"/>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:5px;">
                                        <span class="badge" t-attf-class="badge-#{record.state.raw_value == 'done' ? 'success' : record.state.raw_value == 'in_progress' ? 'warning' : record.state.raw_value == 'review' ? 'info' : 'secondary'}">
                                            <field name="state"/>
                                        </span>
                                        <span class="badge badge-secondary">
                                            <field name="progress"/>%
                                        </span>
                                        <span t-if="record.is_overdue.raw_value" class="badge badge-danger">
                                            ⏰ En retard
                                        </span>
                                    </div>
                                    <div style="margin-top:5px;">
                                        <i class="fa fa-user"/> <field name="owner_id"/>
                                        <i class="fa fa-calendar"/> <field name="deadline"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- ACTION - Tâches                           -->
    <!-- ========================================= -->
    <record id="action_risk_action_task" model="ir.actions.act_window">
        <field name="name">Tâches du plan d'action</field>
        <field name="res_model">risk.action.task</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_risk_action_task_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                ✅ Gérez les tâches de vos plans d'action
            </p>
            <p>
                Chaque tâche contribue à la réalisation du plan d'action.
            </p>
        </field>
    </record>

</odoo>