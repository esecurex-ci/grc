<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ACTION -->
    <record id="action_risk_activity" model="ir.actions.act_window">
        <field name="name">Activités</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">risk.activity</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <!-- LIST VIEW -->
    <record id="view_risk_activity_list" model="ir.ui.view">
        <field name="name">risk.activity.list</field>
        <field name="model">risk.activity</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="macro_process_id"/>
                <field name="process_id"/>
                <field name="owner_id"/>
                <field name="risk_count" widget="statinfo"/>
            </list>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="view_risk_activity_kanban" model="ir.ui.view">
        <field name="name">risk.activity.kanban</field>
        <field name="model">risk.activity</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="code"/>
                <field name="process_id"/>
                <field name="risk_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="code"/> - <field name="name"/>
                                </strong>
                                <div>
                                    <field name="process_id"/>
                                </div>
                                <div class="o_kanban_tags">
                                    <span class="badge bg-info">
                                        <field name="risk_count"/> risques
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_risk_activity_form" model="ir.ui.view">
        <field name="name">risk.activity.form</field>
        <field name="model">risk.activity</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_risks"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-exclamation-triangle">
                            <field name="risk_count" widget="statinfo" string="Risques"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="code" placeholder="Code"/>
                            <field name="name" placeholder="Nom de l'activité..."/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="sequence" widget="handle"/>
                            <field name="macro_process_id"/>
                            <field name="process_id" required="1"/>
                        </group>
                        <group>
                            <field name="owner_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                        <page string="Risques" name="risks">
                            <field name="risk_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="risk_level" widget="badge"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

</odoo>