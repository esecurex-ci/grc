<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================= -->
    <!-- LIST -->
    <!-- ============================= -->

    <record id="view_risk_assessment_list" model="ir.ui.view">
        <field name="name">risk.assessment.list</field>
        <field name="model">risk.assessment</field>
        <field name="arch" type="xml">
            <list multi_edit="1"
                  decoration-success="risk_level == 'low'"
                  decoration-info="risk_level == 'moderate'"
                  decoration-warning="risk_level == 'important'"
                  decoration-danger="risk_level in ('high','critical')">

                <field name="name"/>
                <field name="assessment_date"/>
                <field name="risk_id"/>
                <field name="period_id"/>
                <field name="assessor_id"/>

                <field name="inherent_score"/>

                <field name="residual_score"/>

                <field name="risk_level"
                       widget="badge"/>

                <field name="over_appetite"
                       widget="boolean_toggle"/>

                <field name="state"
                       widget="badge"/>

            </list>
        </field>
    </record>

    <!-- ============================= -->
    <!-- SEARCH -->
    <!-- ============================= -->

    <record id="view_risk_assessment_search" model="ir.ui.view">
        <field name="name">risk.assessment.search</field>
        <field name="model">risk.assessment</field>
        <field name="arch" type="xml">
            <search>

                <field name="name"/>
                <field name="risk_id"/>
                <field name="period_id"/>
                <field name="assessor_id"/>

                <separator/>

                <filter name="critical"
                        string="Critique"
                        domain="[('risk_level','=','critical')]"/>

                <filter name="high"
                        string="Elevé"
                        domain="[('risk_level','=','high')]"/>

                <filter name="over_appetite"
                        string="Hors Appétence"
                        domain="[('over_appetite','=',True)]"/>

                <separator/>

            </search>
        </field>
    </record>

    <!-- ============================= -->
    <!-- FORM -->
    <!-- ============================= -->

    <record id="view_risk_assessment_form" model="ir.ui.view">
        <field name="name">risk.assessment.form</field>
        <field name="model">risk.assessment</field>
        <field name="arch" type="xml">
            <form>

                <header>

                    <button name="action_submit"
                            string="Soumettre"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_review"
                            string="Réviser"
                            type="object"
                            class="btn-info"
                            invisible="state != 'submitted'"/>

                    <button name="action_approve"
                            string="Approuver"
                            type="object"
                            class="btn-success"
                            invisible="state != 'reviewed'"/>

                    <button name="action_close"
                            string="Clôturer"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'approved'"/>

                    <button name="action_reset"
                            string="Réinitialiser"
                            type="object"
                            invisible="state == 'draft'"/>

                    <field name="state"
                           widget="statusbar"/>

                </header>

                <sheet>

                    <div class="oe_button_box" name="button_box">

                        <button class="oe_stat_button"
                                type="object"
                                icon="fa-tasks">

                            <field name="treatment_plan_count"
                                   widget="statinfo"
                                   string="Plans"/>

                        </button>

                    </div>

                    <div class="oe_title">

                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>

                    </div>

                    <group>

                        <group>
                            <field name="risk_id"/>
                            <field name="period_id"/>
                            <field name="assessment_date"/>
                        </group>

                        <group>
                            <field name="assessor_id"/>
                            <field name="company_id"/>
                        </group>

                    </group>

                    <notebook>

                        <page string="Risque Brut">

                            <group>

                                <group>
                                    <field name="inherent_probability"/>
                                    <field name="inherent_impact"/>
                                </group>

                                <group>
                                    <field name="inherent_score"
                                           readonly="1"/>
                                </group>

                            </group>

                        </page>

                        <page string="Contrôles">

                            <group>

                                <field name="control_effectiveness"
                                       widget="progressbar"/>

                            </group>

                        </page>

                        <page string="Risque Résiduel">

                            <group>

                                <group>
                                    <field name="residual_probability"/>
                                    <field name="residual_impact"/>
                                </group>

                                <group>
                                    <field name="residual_score"
                                           readonly="1"/>

                                    <field name="risk_level"
                                           widget="badge"/>

                                    <field name="over_appetite"/>

                                </group>

                            </group>

                        </page>

                        <page string="Traitement">

                            <group>

                                <field name="treatment_strategy"/>

                                <field name="comment"/>

                            </group>

                        </page>

                        <page string="Plans de Traitement">

                            <field name="treatment_plan_ids">

                                <list>
                                    <field name="name"/>
                                </list>

                            </field>

                        </page>

                    </notebook>

                </sheet>

                <chatter/>

            </form>
        </field>
    </record>

</odoo>