<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_risk_asset_list" model="ir.ui.view">
        <field name="name">risk.asset.list</field>
        <field name="model">risk.asset</field>
        <field name="arch" type="xml">
            <list multi_edit="1">
                <field name="code"/>
                <field name="name"/>
                <field name="asset_type" widget="badge"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_risk_asset_form" model="ir.ui.view">
        <field name="name">risk.asset.form</field>
        <field name="model">risk.asset</field>
        <field name="arch" type="xml">
            <form>

                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>

                        <group>
                            <field name="code"/>
                            <field name="asset_type"/>
                        </group>

                        <group>
                            <field name="active"/>
                        </group>

                    </group>

                    <notebook>

                        <page string="Description">
                            <field name="description"/>
                        </page>

                    </notebook>

                </sheet>

            </form>
        </field>
    </record>

    <record id="view_risk_asset_search" model="ir.ui.view">
        <field name="name">risk.asset.search</field>
        <field name="model">risk.asset</field>
        <field name="arch" type="xml">
            <search>

                <field name="code"/>
                <field name="name"/>

                <filter name="application"
                        string="Applications"
                        domain="[('asset_type','=','application')]"/>

                <filter name="server"
                        string="Serveurs"
                        domain="[('asset_type','=','server')]"/>

                <filter name="database"
                        string="Bases de données"
                        domain="[('asset_type','=','database')]"/>


            </search>
        </field>
    </record>

</odoo>