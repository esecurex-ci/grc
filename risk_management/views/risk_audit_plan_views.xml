<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_risk_audit_plan_list" model="ir.ui.view">
        <field name="name">risk.audit.plan.list</field>
        <field name="model">risk.audit.plan</field>
        <field name="arch" type="xml">
            <list multi_edit="1"
                  decoration-info="state == 'draft'"
                  decoration-success="state == 'approved'"
                  decoration-muted="state == 'closed'">

                <field name="name"/>
                <field name="year"/>
                <field name="owner_id"/>
                <field name="state" widget="badge"/>

            </list>
        </field>
    </record>

    <record id="view_risk_audit_plan_form" model="ir.ui.view">
        <field name="name">risk.audit.plan.form</field>
        <field name="model">risk.audit.plan</field>
        <field name="arch" type="xml">

            <form>

                <header>

                    <button name="action_approve"
                            string="Approuver"
                            type="object"
                            class="btn-success"
                            invisible="state != 'draft'"/>

                    <button name="action_close"
                            string="Clôturer"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'approved'"/>

                    <field name="state"
                           widget="statusbar"/>

                </header>

                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="year"/>
                            <field name="owner_id"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Description">
                            <field name="description"/>
                        </page>

                        <page string="Missions">

                            <field name="audit_ids">

                                <list editable="bottom">
                                    <!-- ⬇️ name a été supprimé, on garde title ⬇️ -->
                                    <field name="title"/>
                                    <field name="audit_type"/>
                                    <field name="start_date"/>
                                    <field name="state"/>
                                </list>

                            </field>

                        </page>

                    </notebook>

                </sheet>

                <chatter/>

            </form>

        </field>
    </record>

</odoo>