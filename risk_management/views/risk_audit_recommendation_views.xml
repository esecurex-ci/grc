<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_risk_audit_recommendation_list" model="ir.ui.view">
        <field name="name">risk.audit.recommendation.list</field>
        <field name="model">risk.audit.recommendation</field>
        <field name="arch" type="xml">

            <list>

                <field name="finding_id"/>
                <field name="owner_id"/>
                <field name="priority" widget="badge"/>
                <field name="target_date"/>
                <field name="state" widget="badge"/>

            </list>

        </field>
    </record>

</odoo>