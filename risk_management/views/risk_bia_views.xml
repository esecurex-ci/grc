    <!-- ===================================================== -->
    <!-- FORM -->
    <!-- ===================================================== -->

    <record id="view_risk_bia_form" model="ir.ui.view">
        <field name="name">risk.bia.form</field>
        <field name="model">risk.bia</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve"
                            string="Valider"
                            type="object"
                            class="btn-success"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="priority"/>
                            <field name="impact_operational"/>
                            <field name="impact_financial"/>
                        </group>
                        <group>
                            <field name="mtd" string="MTD (heures)"/>
                            <field name="rto" string="RTO (heures)"/>
                            <field name="rpo" string="RPO (heures)"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>

                </sheet>

                <chatter/>

            </form>

        </field>
    </record>

</odoo>