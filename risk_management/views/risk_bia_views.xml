<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================== -->
    <!-- LIST -->
    <!-- ===================================================== -->

    <record id="view_risk_bia_list" model="ir.ui.view">
        <field name="name">risk.bia.list</field>
        <field name="model">risk.bia</field>
        <field name="arch" type="xml">

            <list>

                <field name="name"/>
                <field name="priority"/>
                <field name="impact_operational"/>
                <field name="impact_financial"/>
                <field name="state" widget="badge"/>

            </list>

        </field>
    </record>

    <!-- ===================================================== -->
    <!-- SEARCH -->
