<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================== -->
    <!-- RECHERCHE - CARTOGRAPHIE                                   -->
    <!-- ========================================================== -->

    <record id="view_risk_cartography_search" model="ir.ui.view">
        <field name="name">risk.cartography.search</field>
        <field name="model">risk.risk</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="category_id"/>
            </search>
        </field>
    </record>

    <!-- ========================================================== -->
    <!-- LISTE - CARTOGRAPHIE                                       -->
    <!-- ========================================================== -->

    <record id="view_risk_cartography_list" model="ir.ui.view">
        <field name="name">risk.cartography.list</field>
        <field name="model">risk.risk</field>
        <field name="arch" type="xml">
            <list
                decoration-success="inherent_level == 'low'"
                decoration-info="inherent_level == 'medium'"
                decoration-warning="inherent_level == 'high'"
                decoration-danger="inherent_level == 'critical'">
                <field name="code"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="inherent_score"/>
                <field name="residual_score"/>
                <field name="inherent_level" widget="badge"
                   class="badge"
                   decoration-success="inherent_level == 'low'"
                   decoration-info="inherent_level == 'medium'"
                   decoration-warning="inherent_level == 'high'"
                   decoration-danger="inherent_level == 'critical'"/>
                <field name="state" widget="badge"
                   class="badge"
                   decoration-success="state == 'validated'"
                   decoration-warning="state == 'draft'"
                   decoration-danger="state == 'obsolete'"/>
            </list>
        </field>
    </record>

    <!-- ========================================================== -->
    <!-- GRAPHIQUE - MATRICE (Scatter)                              -->
    <!-- ========================================================== -->

    <!--record id="view_risk_cartography_graph" model="ir.ui.view">
        <field name="name">risk.cartography.graph</field>
        <field name="model">risk.risk</field>
        <field name="arch" type="xml">
            <graph type="scatter">
                <field name="inherent_score" type="measure"/>
                <field name="residual_score" type="measure"/>
                <field name="inherent_level" type="row"/>
                <field name="category_id" type="col"/>
            </graph>
        </field>
    </record-->

    <!-- ========================================================== -->
    <!-- ACTION - CARTOGRAPHIE                                      -->
    <!-- ========================================================== -->

    <!-- ========================================================== -->
<!-- PIVOT - MATRICE DES RISQUES (CORRIGÉ)                      -->
<!-- ========================================================== -->

    <!-- ========================================================== -->
<!-- GRAPHIQUE - MATRICE EN BARRES EMPILÉES                     -->
<!-- ========================================================== -->

    <record id="view_risk_cartography_bar_matrix" model="ir.ui.view">
        <field name="name">risk.cartography.bar.matrix</field>
        <field name="model">risk.risk</field>
        <field name="arch" type="xml">
            <graph type="bar" stacked="True" string="Distribution Impact × Probabilité">
                <field name="inherent_impact" type="col"/>
                <field name="inherent_probability" type="row"/>
                <field name="inherent_score" type="measure"/>
            </graph>
        </field>
    </record>

</odoo>