<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================== -->
    <!-- RECHERCHE - CARTOGRAPHIE                                   -->
    <!-- ========================================================== -->

    <record id="view_risk_cartography_search" model="ir.ui.view">
        <field name="name">risk.cartography.search</field>
        <field name="model">risk.risk</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="category_id"/>

                <filter name="active"
                        string="Actifs"
                        domain="[('active','=',True)]"/>

                <filter name="critical"
                        string="Critiques"
                        domain="[('inherent_level','=','critical')]"/>

                <filter name="high_risk"
                        string="Élevés"
                        domain="[('inherent_level','in',['high','critical'])]"/>
            </search>
        </field>
    </record>

    <!-- ========================================================== -->
    <!-- LISTE - CARTOGRAPHIE                                       -->
    <!-- ========================================================== -->

    <record id="view_risk_cartography_list" model="ir.ui.view">
        <field name="name">risk.cartography.list</field>
        <field name="model">risk.risk</field>
        <field name="arch" type="xml">
            <list
                decoration-success="inherent_level == 'low'"
                decoration-info="inherent_level == 'medium'"
                decoration-warning="inherent_level == 'high'"
                decoration-danger="inherent_level == 'critical'">
                <field name="code"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="inherent_score"/>
                <field name="residual_score"/>
                <field name="inherent_level" widget="badge"
                   class="badge"
                   decoration-success="inherent_level == 'low'"
                   decoration-info="inherent_level == 'medium'"
                   decoration-warning="inherent_level == 'high'"
                   decoration-danger="inherent_level == 'critical'"/>
                <field name="state" widget="badge"
                   class="badge"
                   decoration-success="state == 'validated'"
                   decoration-warning="state == 'draft'"
                   decoration-danger="state == 'obsolete'"/>
            </list>
        </field>
    </record>

    <!-- ========================================================== -->
    <!-- GRAPHIQUE - MATRICE (Scatter)                              -->
    <!-- ========================================================== -->

    <!--
    <record id="view_risk_cartography_graph" model="ir.ui.view">
        <field name="name">risk.cartography.graph</field>
        <field name="model">risk.risk</field>
        <field name="arch" type="xml">
            <graph type="scatter">
                <field name="impact_value" type="measure"/>
                <field name="probability_value" type="measure"/>
                <field name="inherent_level" type="row"/>
                <field name="category_id" type="col"/>
            </graph>
        </field>
    </record>
    -->

    <!-- ========================================================== -->
    <!-- ACTION - CARTOGRAPHIE                                      -->
    <!-- ========================================================== -->

    <record id="action_risk_cartography" model="ir.actions.act_window">
        <field name="name">📊 Cartographie des risques</field>
        <field name="res_model">risk.risk</field>
        <field name="view_mode">list,graph,form</field>
        <field name="view_id" ref="view_risk_cartography_list"/>
        <field name="search_view_id" ref="view_risk_cartography_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                📊 Cartographie des risques
            </p>
            <p>
                Visualisez l'ensemble des risques de votre organisation.
            </p>
        </field>
    </record>

</odoo>