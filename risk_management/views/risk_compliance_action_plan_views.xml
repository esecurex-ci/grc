<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_risk_compliance_action_plan_list" model="ir.ui.view">
        <field name="name">risk.compliance.action.plan.list</field>
        <field name="model">risk.compliance.action.plan</field>
        <field name="arch" type="xml">

            <list
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'in_progress'"
                  decoration-success="state in ('completed','validated')">

                <field name="name"/>
                <field name="owner_id"/>
                <field name="target_date"/>
                <field name="progress"
                       widget="progressbar"/>
                <field name="state"
                       widget="badge"/>

            </list>

        </field>
    </record>

    <record id="view_risk_compliance_action_plan_form" model="ir.ui.view">
        <field name="name">risk.compliance.action.plan.form</field>
        <field name="model">risk.compliance.action.plan</field>
        <field name="arch" type="xml">

            <form>

                <header>

                    <button name="action_start"
                            type="object"
                            string="Démarrer"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_complete"
                            type="object"
                            string="Terminer"
                            class="btn-success"
                            invisible="state != 'in_progress'"/>

                    <button name="action_validate"
                            type="object"
                            string="Valider"
                            class="btn-info"
                            invisible="state != 'completed'"/>

                    <field name="state"
                           widget="statusbar"/>

                </header>

                <sheet>

                    <group>

                        <field name="assessment_id"/>
                        <field name="owner_id"/>

                    </group>

                    <group>

                        <field name="target_date"/>
                        <field name="completion_date"/>
                        <field name="progress"
                               widget="progressbar"/>

                    </group>

                    <group>
                        <field name="name"/>
                    </group>

                    <group>
                        <field name="description"/>
                    </group>

                </sheet>

                <chatter/>

            </form>

        </field>
    </record>

</odoo>