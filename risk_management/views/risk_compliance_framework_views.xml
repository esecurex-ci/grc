<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_risk_compliance_framework_list" model="ir.ui.view">
        <field name="name">risk.compliance.framework.list</field>
        <field name="model">risk.compliance.framework</field>
        <field name="arch" type="xml">

            <list multi_edit="1">

                <field name="code"/>
                <field name="name"/>
                <field name="version"/>
                <field name="publisher"/>
                <field name="publication_date"/>
                <field name="active"/>

            </list>

        </field>
    </record>

    <record id="view_risk_compliance_framework_form" model="ir.ui.view">
        <field name="name">risk.compliance.framework.form</field>
        <field name="model">risk.compliance.framework</field>
        <field name="arch" type="xml">

            <form>

                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <div class="oe_button_box" name="button_box">

                        <button name="action_view_requirements"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-list-check">

                            <field name="requirement_count"
                                   widget="statinfo"
                                   string="Exigences"/>

                        </button>

                    </div>

                    <group>

                        <group>
                            <field name="code"/>
                            <field name="version"/>
                            <field name="publisher"/>
                        </group>

                        <group>
                            <field name="publication_date"/>
                            <field name="active"/>
                        </group>

                    </group>

                    <notebook>

                        <page string="Description">
                            <field name="description"/>
                        </page>

                        <page string="Exigences">

                            <field name="requirement_ids">

                                <list>
                                    <field name="code"/>
                                    <field name="title"/>
                                    <field name="mandatory"/>
                                </list>

                            </field>

                        </page>

                    </notebook>

                </sheet>

                <chatter/>

            </form>

        </field>
    </record>

</odoo>