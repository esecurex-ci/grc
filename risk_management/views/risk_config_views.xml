<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================== -->
    <!-- VUE LISTE DES VALEURS D'ÉCHELLE                            -->
    <!-- ========================================================== -->

    <record id="view_risk_scale_value_list" model="ir.ui.view">
        <field name="name">risk.scale.value.list</field>
        <field name="model">risk.scale.value</field>
        <field name="arch" type="xml">
            <list>
                <field name="scale_type"/>
                <field name="value"/>
                <field name="numeric_value"/>
                <field name="name"/>
                <field name="color" widget="color"/>
                <field name="score_min"/>
                <field name="score_max"/>
                <field name="sequence"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ========================================================== -->
    <!-- VUE FORMULAIRE DES VALEURS D'ÉCHELLE                       -->
    <!-- ========================================================== -->

    <record id="view_risk_scale_value_form" model="ir.ui.view">
        <field name="name">risk.scale.value.form</field>
        <field name="model">risk.scale.value</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="scale_type"/>
                            <field name="value"/>
                            <!-- invisible au lieu de attrs -->
                            <field name="numeric_value" invisible="scale_type == 'level'"/>
                        </group>
                        <group>
                            <field name="color" widget="color"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <!-- invisible au lieu de attrs -->
                    <group string="Niveaux de risque" invisible="scale_type != 'level'">
                        <field name="score_min"/>
                        <field name="score_max"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================================================== -->
    <!-- VUE DES PARAMÈTRES                                         -->
    <!-- ========================================================== -->

    <record id="view_risk_config_settings" model="ir.ui.view">
        <field name="name">risk.config.settings</field>
        <field name="model">risk.config.settings</field>
        <field name="arch" type="xml">
            <form string="Configuration des échelles" class="o_risk_config_settings">
                <header>
                    <button name="set_values" string="Appliquer" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>⚙️ Configuration des échelles de risque</h1>
                    </div>

                    <group string="Échelle de probabilité">
                        <field name="scale_probability_ids" widget="many2many_tags"/>
                    </group>

                    <group string="Échelle d'impact">
                        <field name="scale_impact_ids" widget="many2many_tags"/>
                    </group>

                    <group string="Niveaux de risque">
                        <field name="scale_level_ids" widget="many2many_tags"/>
                    </group>

                    <div class="alert alert-info" role="alert">
                        <i class="fa fa-info-circle"/>
                        Les modifications seront appliquées après avoir cliqué sur "Appliquer".
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================================================== -->
    <!-- ACTIONS                                                    -->
    <!-- ========================================================== -->

    <record id="action_risk_scale_value" model="ir.actions.act_window">
        <field name="name">Valeurs d'échelle</field>
        <field name="res_model">risk.scale.value</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_risk_config_settings" model="ir.actions.act_window">
        <field name="name">Configurer les échelles</field>
        <field name="res_model">risk.config.settings</field>
        <field name="view_mode">form</field>
        <!-- target "current" est la valeur par défaut, on peut l'omettre -->
    </record>

</odoo>