<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- VUE LISTE -->
    <record id="view_risk_control_test_list" model="ir.ui.view">
        <field name="name">risk.control.test.list</field>
        <field name="model">risk.control.test</field>
        <field name="arch" type="xml">
            <list decoration-success="result == 'pass'"
                  decoration-warning="result == 'partial'"
                  decoration-danger="result == 'fail'">
                <field name="code"/>
                <field name="name"/>
                <field name="control_id"/>
                <field name="test_date"/>
                <field name="tester_id"/>
                <field name="result" widget="badge"/>
                <field name="result_score" widget="progressbar"/>
                <field name="error_count"/>
                <field name="compliance_rate" widget="progressbar"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- VUE FORMULAIRE -->
    <record id="view_risk_control_test_form" model="ir.ui.view">
        <field name="name">risk.control.test.form</field>
        <field name="model">risk.control.test</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_plan" string="📅 Planifier" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_start" string="🔄 Démarrer" type="object"
                            class="btn-warning" invisible="state != 'planned'"/>
                    <button name="action_pass" string="✅ Réussi" type="object"
                            class="btn-success" invisible="state != 'in_progress'"/>
                    <button name="action_fail" string="❌ Échec" type="object"
                            class="btn-danger" invisible="state != 'in_progress'"/>
                    <button name="action_partial" string="⚠️ Partiel" type="object"
                            class="btn-warning" invisible="state != 'in_progress'"/>
                    <button name="action_create_corrective_action" string="🔧 Créer action corrective" type="object"
                            class="btn-secondary" invisible="result not in ['fail', 'partial']"/>
                    <button name="action_cancel" string="❌ Annuler" type="object"
                            class="btn-danger" invisible="state in ['done', 'cancelled']"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nom du test..."/>
                        </h1>
                        <span class="oe_subtitle">
                            <field name="code" placeholder="Code"/>
                            <span class="badge badge-secondary"><field name="control_id"/></span>
                            <span class="badge badge-info"><field name="result" widget="badge"/></span>
                        </span>
                    </div>

                    <group>
                        <group>
                            <field name="control_id" required="1"/>
                            <field name="test_date" required="1"/>
                            <field name="tester_id" required="1"/>
                            <field name="test_method"/>
                            <field name="sample_size"/>
                        </group>
                        <group>
                            <field name="result" widget="badge"/>
                            <field name="result_score" readonly="1" widget="progressbar"/>
                            <field name="error_count"/>
                            <field name="error_rate" readonly="1" widget="progressbar"/>
                            <field name="compliance_rate" readonly="1" widget="progressbar"/>
                            <field name="state" widget="badge"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="📝 Détails">
                            <field name="details" widget="html"/>
                            <field name="deviation" widget="html"/>
                            <field name="recommendation" widget="html"/>
                        </page>
                        <page string="🔧 Actions correctives" invisible="not action_ids">
                            <field name="action_ids" context="{'default_control_test_id': id}">
                                <list>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="state" widget="badge"/>
                                    <field name="deadline"/>
                                    <field name="owner_id"/>
                                    <field name="progress" widget="progressbar"/>
                                </list>
                            </field>
                        </page>
                        <page string="📎 Pièces jointes">
                            <field name="attachment_ids" widget="many2many_kanban"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_risk_control_test" model="ir.actions.act_window">
        <field name="name">Tests de contrôle</field>
        <field name="res_model">risk.control.test</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>