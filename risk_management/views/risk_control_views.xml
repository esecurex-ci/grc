<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_risk_control_list" model="ir.ui.view">
        <field name="name">risk.control.list</field>
        <field name="model">risk.control</field>
        <field name="arch" type="xml">
            <list
                  decoration-success="effectiveness &gt;= 80"
                  decoration-warning="effectiveness &gt;= 50 and effectiveness &lt; 80"
                  decoration-danger="effectiveness &lt; 50">

                <field name="code"/>
                <field name="name"/>
                <field name="control_type" widget="badge"/>
                <field name="owner_id"/>
                <field name="frequency"/>
                <field name="automation_level"/>
                <field name="effectiveness" widget="progressbar"/>
                <field name="active"/>

            </list>
        </field>
    </record>

    <record id="view_risk_control_search" model="ir.ui.view">
        <field name="name">risk.control.search</field>
        <field name="model">risk.control</field>
        <field name="arch" type="xml">
            <search>

                <field name="code"/>
                <field name="name"/>
                <field name="owner_id"/>

                <filter name="preventive"
                        string="Préventif"
                        domain="[('control_type','=','preventive')]"/>

                <filter name="detective"
                        string="Détectif"
                        domain="[('control_type','=','detective')]"/>

                <filter name="corrective"
                        string="Correctif"
                        domain="[('control_type','=','corrective')]"/>



            </search>
        </field>
    </record>

    <record id="view_risk_control_form" model="ir.ui.view">
        <field name="name">risk.control.form</field>
        <field name="model">risk.control</field>
        <field name="arch" type="xml">

            <form>

                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>

                        <group>
                            <field name="code"/>
                            <field name="owner_id"/>
                            <field name="control_type"/>
                        </group>

                        <group>
                            <field name="frequency"/>
                            <field name="automation_level"/>
                            <field name="active"/>
                        </group>

                    </group>

                    <group>
                        <field name="effectiveness"
                               widget="progressbar"
                               readonly="1"/>
                    </group>

                    <notebook>

                        <page string="Description">
                            <field name="description"/>
                        </page>

                        <page string="Objectif">
                            <field name="objective"/>
                        </page>

                        <page string="Risques">

                            <field name="risk_ids"
                                   widget="many2many_tags"/>

                        </page>

                        <page string="Conformité">

                            <field name="compliance_requirement_ids"
                                   widget="many2many_tags"/>

                        </page>

                        <page string="Tests">

                            <field name="test_ids">

                                <list editable="bottom">

                                    <field name="name"/>
                                    <field name="test_date"/>
                                    <field name="tester_id"/>
                                    <field name="result_score"/>
                                    <field name="result"/>

                                </list>

                            </field>

                        </page>

                    </notebook>

                </sheet>

                <chatter/>

            </form>

        </field>
    </record>

</odoo>