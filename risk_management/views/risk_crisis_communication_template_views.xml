<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_risk_crisis_communication_template_list"
            model="ir.ui.view">

        <field name="name">risk.crisis.communication.template.list</field>
        <field name="model">risk.crisis.communication.template</field>

        <field name="arch" type="xml">

            <list multi_edit="1">

                <field name="code"/>

                <field name="name"/>

                <field name="audience"
                       widget="badge"/>

                <field name="active"/>

            </list>

        </field>

    </record>

    <record id="view_risk_crisis_communication_template_form"
            model="ir.ui.view">

        <field name="name">risk.crisis.communication.template.form</field>
        <field name="model">risk.crisis.communication.template</field>

        <field name="arch" type="xml">

            <form>

                <sheet>

                    <group>

                        <group>

                            <field name="code"/>

                            <field name="name"/>

                        </group>

                        <group>

                            <field name="audience"/>

                            <field name="active"/>

                        </group>

                    </group>

                    <group>

                        <field name="subject"/>

                    </group>

                    <field name="body"/>

                </sheet>

            </form>

        </field>

    </record>

</odoo>