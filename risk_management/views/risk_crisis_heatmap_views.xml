<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_risk_crisis_heatmap_list"
            model="ir.ui.view">

        <field name="name">risk.crisis.heatmap.list</field>
        <field name="model">risk.crisis.heatmap</field>
        <field name="arch" type="xml">

            <list decoration-success="risk_level == 'low'"
                  decoration-info="risk_level == 'medium'"
                  decoration-warning="risk_level == 'high'"
                  decoration-danger="risk_level == 'critical'">
                <field name="name"/>
                <field name="scenario_id"/>
                <field name="likelihood"/>
                <field name="impact"/>
                <field name="score"/>
                <field name="risk_level" widget="badge"/>

            </list>

        </field>

    </record>

</odoo>