<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_risk_crisis_lessons_dashboard_form"
            model="ir.ui.view">

        <field name="name">
            risk.crisis.lessons.dashboard.form
        </field>

        <field name="model">
            risk.crisis.lessons.learned.dashboard
        </field>

        <field name="arch" type="xml">

            <form create="false"
                  edit="false">

                <sheet>

                    <group col="4">

                        <field name="total_rex"/>

                        <field name="implemented_rex"/>

                        <field name="pending_rex"/>

                        <field name="implementation_rate"
                               widget="progressbar"/>

                    </group>

                </sheet>

            </form>

        </field>

    </record>

</odoo>