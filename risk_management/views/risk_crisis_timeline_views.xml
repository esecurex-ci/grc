<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_risk_crisis_timeline_list"
            model="ir.ui.view">

        <field name="name">risk.crisis.timeline.list</field>
        <field name="model">risk.crisis.timeline</field>

        <field name="arch" type="xml">

            <list decoration-info="event_type == 'communication'"
                  decoration-warning="event_type == 'decision'"
                  decoration-success="event_type == 'resolution'">

                <field name="event_date"/>

                <field name="event_type"
                       widget="badge"/>

                <field name="title"/>

                <field name="owner_id"/>

            </list>

        </field>

    </record>

    <record id="view_risk_crisis_timeline_form"
            model="ir.ui.view">

        <field name="name">risk.crisis.timeline.form</field>
        <field name="model">risk.crisis.timeline</field>

        <field name="arch" type="xml">

            <form>

                <sheet>

                    <group>

                        <group>

                            <field name="crisis_id"/>

                            <field name="event_date"/>

                        </group>

                        <group>

                            <field name="event_type"/>

                            <field name="owner_id"/>

                        </group>

                    </group>

                    <group>

                        <field name="title"/>

                    </group>

                    <field name="description"/>

                </sheet>

            </form>

        </field>

    </record>

</odoo>