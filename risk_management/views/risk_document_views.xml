<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================= -->
    <!-- VUE LISTE - Documents                     -->
    <!-- ========================================= -->
    <record id="view_risk_document_list" model="ir.ui.view">
        <field name="name">risk.document.list</field>
        <field name="model">risk.document</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'published'"
                  decoration-info="state == 'approved'"
                  decoration-warning="state in ('review', 'preparation')"
                  decoration-danger="state in ('obsolete', 'archived')"
                  decoration-muted="state == 'draft'">
                <field name="code"/>
                <field name="name"/>
                <field name="document_type" widget="badge"/>
                <field name="category_id"/>
                <field name="state" widget="badge"/>
                <field name="version_label"/>
                <field name="version_count" widget="badge" string="📋"/>
                <!-- ✅ REMPLACÉ : owner_id pointe maintenant vers risk.function -->
                <field name="owner_id" string="Propriétaire"/>
                <field name="review_status" widget="badge"/>
                <field name="review_due" widget="boolean" string="⚠️"/>
                <field name="active" widget="boolean"/>
            </list>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- VUE FORMULAIRE - Document                 -->
    <!-- ========================================= -->
    <record id="view_risk_document_form" model="ir.ui.view">
        <field name="name">risk.document.form</field>
        <field name="model">risk.document</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Workflow buttons -->
                    <button name="action_submit_review" string="📤 Soumettre à relecture" type="object"
                            class="btn-primary" invisible="state not in ['preparation', 'draft']"/>
                    <button name="action_approve" string="✅ Approuver" type="object"
                            class="btn-success" invisible="state != 'review'"/>
                    <button name="action_publish" string="📤 Publier" type="object"
                            class="btn-info" invisible="state != 'approved'"/>
                    <button name="action_archive" string="📦 Archiver" type="object"
                            class="btn-secondary" invisible="state in ['obsolete', 'archived']"/>
                    <button name="action_obsolete" string="🚫 Rendre obsolète" type="object"
                            class="btn-danger" invisible="state in ['obsolete', 'archived', 'draft']"/>

                    <!-- Version buttons -->
                    <button name="action_view_versions" string="📋 Versions" type="object"
                            class="btn-secondary" invisible="version_count == 0"/>
                    <button name="action_create_version" string="➕ Nouvelle version" type="object" class="btn-primary"/>

                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Titre du document..."/>
                        </h1>
                        <span class="oe_subtitle">
                            <field name="code" placeholder="Code"/>
                            <span class="badge badge-secondary"><field name="version_label"/></span>
                            <span class="badge badge-success" invisible="not is_current">⭐ Actif</span>
                        </span>
                    </div>

                    <!-- Informations principales -->
                    <group>
                        <group string="Informations générales">
                            <field name="document_type" widget="badge"/>
                            <field name="category_id" required="1"/>
                            <field name="process_id"/>
                            <field name="confidentiality" widget="badge"/>
                            <field name="language"/>
                            <field name="keywords"/>
                            <field name="tags" widget="many2many_tags"/>
                        </group>
                        <group string="Responsables (Fonctions)">
                            <!-- ✅ REMPLACÉ : risk.function au lieu de hr.employee -->
                            <field name="owner_id" widget="many2one_avatar"
                                   placeholder="Fonction propriétaire"
                                   options="{'no_create': True}"/>
                            <field name="author_id" widget="many2one_avatar"
                                   placeholder="Fonction auteur"
                                   options="{'no_create': True}"/>
                            <field name="reviewer_id" widget="many2one_avatar"
                                   placeholder="Fonction relecteur"
                                   options="{'no_create': True}"/>
                            <field name="approver_id" widget="many2one_avatar"
                                   placeholder="Fonction approbateur"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>

                    <!-- Employés (information supplémentaire) -->
                    <group string="Employés (Information)" colspan="2">
                        <group>
                            <field name="owner_employee_id" widget="many2one_avatar"
                                   placeholder="Employé propriétaire"/>
                            <field name="author_employee_id" widget="many2one_avatar"
                                   placeholder="Employé auteur"/>
                        </group>
                    </group>

                    <!-- Version info -->
                    <group string="Informations de version" colspan="2">
                        <group>
                            <field name="version_major"/>
                            <field name="version_minor"/>
                            <field name="version_label" readonly="1"/>
                            <field name="current_version_id" readonly="1"/>
                            <field name="creation_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="version_count" readonly="1"/>
                            <field name="review_frequency"/>
                            <field name="last_review_date" readonly="1"/>
                            <field name="next_review_date"/>
                            <field name="review_status" widget="badge"/>
                            <field name="expiry_date"/>
                            <field name="effective_date"/>
                        </group>
                    </group>

                    <!-- Description et contenu -->
                    <notebook>
                        <page string="📝 Description">
                            <field name="summary" placeholder="Résumé du document..."/>
                            <field name="description" placeholder="Description détaillée..." widget="html"/>
                            <field name="objective" placeholder="Objectif du document..." widget="html"/>
                            <field name="scope" placeholder="Périmètre d'application..." widget="html"/>
                        </page>

                        <page string="📋 Contenu">
                            <field name="content" widget="html" placeholder="Contenu complet du document..."/>
                        </page>

                        <!-- PAGE : VERSIONS -->
                        <page string="📋 Versions" invisible="version_count == 0">
                            <div class="alert alert-info" style="margin-bottom:10px;">
                                <i class="fa fa-info-circle"/>
                                <strong><field name="version_count"/></strong> version(s) disponible(s)
                                <span class="text-muted"> - Version actuelle : <field name="version_label"/></span>
                            </div>
                            <!-- ✅ CORRIGÉ : active_id → id -->
                            <field name="version_ids" context="{'default_document_id': id}">
                                <list decoration-success="state == 'published'"
                                      decoration-info="state == 'approved'"
                                      decoration-warning="state == 'review'"
                                      decoration-danger="state == 'archived'">
                                    <field name="version_label"/>
                                    <field name="state" widget="badge"/>
                                    <field name="filename"/>
                                    <field name="file_size" string="Taille (Ko)"/>
                                    <field name="author_id"/>
                                    <field name="creation_date"/>
                                    <field name="changelog" optional="hide"/>
                                    <field name="is_current" widget="boolean" string="⭐"/>
                                    <field name="is_obsolete" widget="boolean" string="🚫"/>
                                </list>
                            </field>
                            <div style="margin-top:10px;">
                                <button name="action_create_version" string="➕ Nouvelle version" type="object"
                                        class="btn-primary btn-sm"/>
                                <button name="action_view_versions" string="📋 Voir toutes les versions" type="object"
                                        class="btn-secondary btn-sm"/>
                            </div>
                        </page>

                        <!-- PAGE : DOCUMENTS JOINTS -->
                        <page string="📎 Documents joints">
                            <div class="alert alert-info" style="margin-bottom:10px;">
                                <i class="fa fa-info-circle"/>
                                <strong><field name="attachment_count"/></strong> document(s) joint(s)
                            </div>
                            <field name="attachment_ids" widget="many2many_kanban"
                                   options="{'reload_on_write': True}"/>
                        </page>

                        <!-- PAGE : RISQUES & CONTROLES -->
                        <page string="🔗 Risques &amp; Contrôles">
                            <group string="Risques couverts">
                                <field name="risk_ids"/>
                            </group>
                            <group string="Contrôles associés">
                                <field name="control_ids"/>
                            </group>
                            <group string="Réglementations liées">
                                <field name="regulation_ids"/>
                            </group>
                        </page>

                        <!-- PAGE : REVUES -->
                        <page string="📝 Revues" invisible="review_count == 0">
                            <field name="review_ids" context="{'default_document_id': id}">
                                <list>
                                    <field name="review_date"/>
                                    <field name="reviewer_id"/>
                                    <field name="status" widget="badge"/>
                                    <field name="comments"/>
                                </list>
                            </field>
                        </page>

                        <!-- PAGE : APPROBATIONS -->
                        <page string="✅ Approbations" invisible="approval_count == 0">
                            <field name="approval_ids" context="{'default_document_id': id}">
                                <list decoration-success="status == 'approved'"
                                      decoration-warning="status == 'pending'"
                                      decoration-danger="status == 'rejected'">
                                    <field name="approver_id"/>
                                    <field name="approval_date"/>
                                    <field name="status" widget="badge"/>
                                    <field name="comments"/>
                                </list>
                            </field>
                        </page>

                        <!-- PAGE : DISTRIBUTION -->
                        <page string="📤 Distribution" invisible="distribution_count == 0">
                            <field name="distribution_ids" context="{'default_document_id': id}">
                                <list>
                                    <field name="employee_id"/>
                                    <field name="read_date"/>
                                    <field name="confirmed" widget="boolean"/>
                                    <field name="training_completed" widget="boolean"/>
                                </list>
                            </field>
                        </page>

                        <!-- PAGE : HISTORIQUE -->
                        <page string="📜 Historique">
                            <field name="message_ids" widget="mail_thread"/>
                        </page>
                    </notebook>
                </sheet>

                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- VUE KANBAN - Documents                    -->
    <!-- ========================================= -->
    <!-- ========================================= -->
    <!-- VUE KANBAN - Documents (version stable)   -->
    <!-- ========================================= -->
    <record id="view_risk_document_kanban" model="ir.ui.view">
        <field name="name">risk.document.kanban</field>
        <field name="model">risk.document</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="code"/>
                <field name="document_type"/>
                <field name="state"/>
                <field name="version_label"/>
                <field name="category_id"/>
                <field name="owner_id"/>
                <field name="attachment_count"/>
                <field name="review_status"/>
                <field name="active"/>
                <field name="version_count"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <i class="fa fa-file-text-o" style="font-size: 32px;"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="text-muted o_kanban_record_subtitle">
                                    <field name="code"/> - <field name="version_label"/>
                                </div>
                                <div class="o_kanban_primary_dashboard">
                                    <div class="o_kanban_dashboard">
                                        <div class="o_kanban_dashboard_item">
                                            <span class="o_kanban_dashboard_value"><field name="version_count"/></span>
                                            <span class="o_kanban_dashboard_title">Versions</span>
                                        </div>
                                        <div class="o_kanban_dashboard_item">
                                            <span class="o_kanban_dashboard_value"><field name="attachment_count"/></span>
                                            <span class="o_kanban_dashboard_title">Documents</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="o_kanban_secondary_dashboard">
                                    <span class="badge" t-attf-class="badge-#{record.state.value == 'published' ? 'success' : record.state.value == 'approved' ? 'info' : record.state.value == 'review' ? 'warning' : 'secondary'}">
                                        <field name="state"/>
                                    </span>
                                    <span class="badge badge-secondary">
                                        <field name="document_type"/>
                                    </span>
                                    <span class="badge badge-light">
                                        <i class="fa fa-folder"/> <field name="category_id"/>
                                    </span>
                                </div>
                                <div>
                                    <i class="fa fa-building"/> <field name="owner_id"/>
                                </div>
                                <div class="text-danger" invisible="review_status.value != 'overdue'">
                                    <i class="fa fa-exclamation-triangle"/> Révision en retard
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- VUE RECHERCHE - Documents                -->
    <!-- ========================================= -->
    <record id="view_risk_document_search" model="ir.ui.view">
        <field name="name">risk.document.search</field>
        <field name="model">risk.document</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Titre"/>
                <field name="code" string="Code"/>
                <field name="keywords"/>
                <field name="summary"/>
                <!-- ✅ REMPLACÉ : owner_id pointe vers risk.function -->
                <field name="owner_id" string="Propriétaire"/>
                <field name="author_id" string="Auteur"/>
                <field name="reviewer_id" string="Relecteur"/>
                <field name="approver_id" string="Approbateur"/>
                <field name="category_id" string="Catégorie"/>

                <filter name="state_draft" string="Brouillon" domain="[('state', '=', 'draft')]"/>
                <filter name="state_preparation" string="En préparation" domain="[('state', '=', 'preparation')]"/>
                <filter name="state_review" string="En relecture" domain="[('state', '=', 'review')]"/>
                <filter name="state_approval" string="En approbation" domain="[('state', '=', 'approval')]"/>
                <filter name="state_approved" string="Approuvé" domain="[('state', '=', 'approved')]"/>
                <filter name="state_published" string="Publié" domain="[('state', '=', 'published')]"/>
                <filter name="state_obsolete" string="Obsolète" domain="[('state', '=', 'obsolete')]"/>
                <filter name="state_archived" string="Archivé" domain="[('state', '=', 'archived')]"/>

                <separator/>

                <filter name="type_policy" string="Politique" domain="[('document_type', '=', 'policy')]"/>
                <filter name="type_procedure" string="Procédure" domain="[('document_type', '=', 'procedure')]"/>
                <filter name="type_standard" string="Standard" domain="[('document_type', '=', 'standard')]"/>
                <filter name="type_guideline" string="Guideline" domain="[('document_type', '=', 'guideline')]"/>

                <separator/>

                <filter name="review_due" string="Révision due" domain="[('review_status', '=', 'due')]"/>
                <filter name="review_overdue" string="Révision en retard" domain="[('review_status', '=', 'overdue')]"/>
                <filter name="has_versions" string="Avec versions" domain="[('version_count', '>', 0)]"/>
                <filter name="has_attachments" string="Avec documents joints" domain="[('attachment_count', '>', 0)]"/>
                <filter name="active" string="Actif" domain="[('active', '=', True)]"/>

                <separator/>

                <filter name="group_category" string="Par catégorie" context="{'group_by': 'category_id'}"/>
                <filter name="group_type" string="Par type" context="{'group_by': 'document_type'}"/>
                <filter name="group_state" string="Par statut" context="{'group_by': 'state'}"/>
                <filter name="group_owner" string="Par propriétaire" context="{'group_by': 'owner_id'}"/>
                <filter name="group_author" string="Par auteur" context="{'group_by': 'author_id'}"/>
            </search>
        </field>
    </record>

</odoo>