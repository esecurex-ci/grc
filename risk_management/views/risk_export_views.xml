<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================= -->
    <!-- ASSISTANT D'EXPORT                        -->
    <!-- ========================================= -->
    <record id="view_risk_export_wizard_form" model="ir.ui.view">
        <field name="name">risk.export.wizard.form</field>
        <field name="model">risk.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Exporter les données GRC">
                <sheet>
                    <div class="oe_title">
                        <h1>📦 Export des données GRC</h1>
                        <p class="text-muted">
                            Exportez toutes vos données de gestion des risques avec leurs relations.
                        </p>
                    </div>

                    <group>
                        <group>
                            <field name="export_type" required="1" widget="radio"/>
                            <field name="export_format" required="1" widget="radio"/>
                        </group>
                        <group>
                            <field name="include_relations"/>
                            <field name="include_historical"/>
                        </group>
                    </group>

                    <!-- Statistiques d'aperçu -->
                    <group string="Aperçu des données" colspan="2">
                        <group>
                            <field name="total_risks" nolabel="1" class="oe_inline"/>
                        </group>
                        <group>
                            <field name="total_controls" nolabel="1" class="oe_inline"/>
                        </group>
                        <group>
                            <field name="total_incidents" nolabel="1" class="oe_inline"/>
                        </group>
                        <group>
                            <field name="total_kris" nolabel="1" class="oe_inline"/>
                        </group>
                    </group>

                    <!-- Fichier généré -->
                    <group string="Fichier généré" colspan="2" invisible="state != 'done'">
                        <div class="alert alert-success" role="status" style="margin-top: 5px;">
                            <i class="fa fa-check-circle" title="Succès"/>
                            <strong>✅ Export terminé !</strong>
                            <div style="margin-top: 8px;">
                                <field name="file_name" readonly="1" style="margin-bottom: 5px;"/>
                                <br/>
                                <button name="action_download" string="📥 Télécharger" type="object" class="btn-primary"/>
                            </div>
                        </div>
                    </group>

                    <footer>
                        <button name="action_export" string="📤 Exporter" type="object" class="btn-primary"
                                invisible="state == 'done'"/>
                        <button string="Fermer" special="cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- ASSISTANT D'IMPORT                        -->
    <!-- ========================================= -->
    <record id="view_risk_import_wizard_form" model="ir.ui.view">
        <field name="name">risk.import.wizard.form</field>
        <field name="model">risk.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importer des données GRC">
                <sheet>
                    <div class="oe_title">
                        <h1>📥 Import des données GRC</h1>
                        <p class="text-muted">
                            Importez des données depuis un fichier JSON, XML ou CSV.
                            Les données importées doivent respecter le format d'export.
                        </p>
                    </div>

                    <group>
                        <group>
                            <field name="file_data" filename="file_name" widget="binary" required="1"/>
                            <field name="file_name" readonly="1"/>
                            <field name="import_type" required="1" widget="radio"/>
                            <field name="dry_run"/>
                        </group>
                        <group>
                            <field name="import_log" nolabel="1" widget="text"
                                   placeholder="Le journal d'import s'affichera ici..."/>
                        </group>
                    </group>

                    <footer>
                        <button name="action_import" string="📥 Importer" type="object" class="btn-primary"
                                confirm="Voulez-vous vraiment importer ces données ?"/>
                        <button string="Fermer" special="cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

</odoo>