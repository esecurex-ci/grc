<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================= -->
    <!-- FORMULAIRE                                -->
    <!-- ========================================= -->
    <record id="view_risk_function_form" model="ir.ui.view">
        <field name="name">risk.function.form</field>
        <field name="model">risk.function</field>
        <field name="arch" type="xml">
            <form string="Fonction">
                <header>
                    <button name="action_activate" string="Activer" type="object" class="btn-success"
                            invisible="state != 'draft'"/>
                    <button name="action_review" string="Marquer comme révisé" type="object" class="btn-info"
                            invisible="state == 'archived'"/>
                    <button name="action_archive" string="Archiver" type="object" class="btn-danger"
                            invisible="state == 'archived'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,archived"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nom de la fonction..." />
                        </h1>
                        <span class="oe_subtitle">
                            <field name="code" readonly="1"/>
                        </span>
                    </div>

                    <group>
                        <group string="Informations générales">
                            <field name="parent_id" widget="many2one_avatar" options="{'no_create': True}"
                                   placeholder="Fonction parente"/>
                            <field name="complete_name" readonly="1"/>
                            <field name="level" readonly="1"/>
                            <field name="department_id" placeholder="Département"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Responsables">
                            <field name="manager_id" widget="many2one_avatar" placeholder="Responsable de la fonction"/>
                            <field name="deputy_manager_id" widget="many2one_avatar" placeholder="Responsable adjoint"/>
                            <field name="creation_date"/>
                            <field name="last_review_date"/>
                            <field name="next_review_date"/>
                            <field name="review_frequency"/>
                        </group>
                    </group>

                    <group string="Description">
                        <field name="description" placeholder="Description de la fonction..." nolabel="1"/>
                    </group>

                    <group string="Statistiques" colspan="2">
                        <group>
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="risk_count"/></span>
                                <span class="o_stat_text">Risques</span>
                            </div>
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="control_count"/></span>
                                <span class="o_stat_text">Contrôles</span>
                            </div>
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="kri_count"/></span>
                                <span class="o_stat_text">KRI</span>
                            </div>
                        </group>
                        <group>
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="incident_count"/></span>
                                <span class="o_stat_text">Incidents</span>
                            </div>
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="document_count"/></span>
                                <span class="o_stat_text">Documents</span>
                            </div>
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="avg_risk_score"/></span>
                                <span class="o_stat_text">Score moyen</span>
                            </div>
                        </group>
                    </group>

                    <group string="Distribution des risques" colspan="2">
                        <div style="display: flex; gap: 15px; flex-wrap: wrap; padding: 10px 0;">
                            <div style="border-left: 4px solid #dc3545; padding-left: 10px; background: #f8f9fa; border-radius: 4px; padding: 8px 15px;">
                                <span style="font-size: 20px; font-weight: bold; color: #dc3545;">
                                    <field name="critical_risk_count" nolabel="1"/>
                                </span>
                                <span style="color: #6c757d; font-size: 12px;">Critiques</span>
                            </div>
                            <div style="border-left: 4px solid #fd7e14; padding-left: 10px; background: #f8f9fa; border-radius: 4px; padding: 8px 15px;">
                                <span style="font-size: 20px; font-weight: bold; color: #fd7e14;">
                                    <field name="high_risk_count" nolabel="1"/>
                                </span>
                                <span style="color: #6c757d; font-size: 12px;">Élevés</span>
                            </div>
                            <div style="border-left: 4px solid #ffc107; padding-left: 10px; background: #f8f9fa; border-radius: 4px; padding: 8px 15px;">
                                <span style="font-size: 20px; font-weight: bold; color: #ffc107;">
                                    <field name="medium_risk_count" nolabel="1"/>
                                </span>
                                <span style="color: #6c757d; font-size: 12px;">Moyens</span>
                            </div>
                            <div style="border-left: 4px solid #28a745; padding-left: 10px; background: #f8f9fa; border-radius: 4px; padding: 8px 15px;">
                                <span style="font-size: 20px; font-weight: bold; color: #28a745;">
                                    <field name="low_risk_count" nolabel="1"/>
                                </span>
                                <span style="color: #6c757d; font-size: 12px;">Faibles</span>
                            </div>
                        </div>
                    </group>

                    <notebook>
                        <page string="Risques" invisible="risk_count == 0">
                            <field name="risk_ids" nolabel="1" domain="[('active', '=', True)]"/>
                        </page>
                        <page string="Contrôles" invisible="control_count == 0">
                            <field name="control_ids" nolabel="1"/>
                        </page>
                        <page string="KRI" invisible="kri_count == 0">
                            <field name="kri_ids" nolabel="1"/>
                        </page>
                        <page string="Incidents" invisible="incident_count == 0">
                            <field name="incident_ids" nolabel="1"/>
                        </page>
                        <page string="Documents" invisible="document_count == 0">
                            <field name="document_ids" nolabel="1"/>
                        </page>
                        <page string="Sous-fonctions" invisible="not child_ids">
                            <field name="child_ids" nolabel="1" context="{'default_parent_id': id}"/>
                        </page>
                    </notebook>
                </sheet>

                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- VUE LISTE                                 -->
    <!-- ========================================= -->
    <record id="view_risk_function_list" model="ir.ui.view">
        <field name="name">risk.function.list</field>
        <field name="model">risk.function</field>
        <field name="arch" type="xml">
            <list string="Fonctions" decoration-success="state == 'active'"
                  decoration-warning="state == 'draft'"
                  decoration-muted="state == 'archived'">
                <field name="complete_name" string="Nom"/>
                <field name="code" optional="hide"/>
                <field name="manager_id" optional="show"/>
                <field name="department_id" optional="show"/>
                <field name="risk_count" sum="Total"/>
                <field name="control_count"/>
                <field name="kri_count" optional="hide"/>
                <field name="incident_count" optional="hide"/>
                <field name="avg_risk_score" optional="show"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- VUE KANBAN - Documents (version stable)   -->
    <!-- ========================================= -->
    <record id="view_risk_document_kanban" model="ir.ui.view">
        <field name="name">risk.document.kanban</field>
        <field name="model">risk.document</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="code"/>
                <field name="document_type"/>
                <field name="state"/>
                <field name="version_label"/>
                <field name="category_id"/>
                <field name="owner_id"/>
                <field name="attachment_count"/>
                <field name="review_status"/>
                <field name="active"/>
                <field name="version_count"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <i class="fa fa-file-text-o" style="font-size: 32px;"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="text-muted o_kanban_record_subtitle">
                                    <field name="code"/> - <field name="version_label"/>
                                </div>
                                <div class="o_kanban_primary_dashboard">
                                    <div class="o_kanban_dashboard">
                                        <div class="o_kanban_dashboard_item">
                                            <span class="o_kanban_dashboard_value"><field name="version_count"/></span>
                                            <span class="o_kanban_dashboard_title">Versions</span>
                                        </div>
                                        <div class="o_kanban_dashboard_item">
                                            <span class="o_kanban_dashboard_value"><field name="attachment_count"/></span>
                                            <span class="o_kanban_dashboard_title">Documents</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="o_kanban_secondary_dashboard">
                                    <span class="badge" t-attf-class="badge-#{record.state.value == 'published' ? 'success' : record.state.value == 'approved' ? 'info' : record.state.value == 'review' ? 'warning' : 'secondary'}">
                                        <field name="state"/>
                                    </span>
                                    <span class="badge badge-secondary">
                                        <field name="document_type"/>
                                    </span>
                                    <span class="badge badge-light">
                                        <i class="fa fa-folder"/> <field name="category_id"/>
                                    </span>
                                </div>
                                <div>
                                    <i class="fa fa-building"/> <field name="owner_id"/>
                                </div>
                                <div class="text-danger" invisible="review_status.value != 'overdue'">
                                    <i class="fa fa-exclamation-triangle"/> Révision en retard
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- VUE RECHERCHE - CORRIGÉE                 -->
    <!-- ========================================= -->
    <record id="view_risk_function_search" model="ir.ui.view">
        <field name="name">risk.function.search</field>
        <field name="model">risk.function</field>
        <field name="arch" type="xml">
            <search string="Rechercher une fonction">
                <field name="name" string="Nom"/>
                <field name="code" string="Code"/>
                <field name="manager_id" string="Responsable"/>
                <filter name="active" string="Actives" domain="[('active','=',True)]" help="Fonctions actives"/>
                <filter name="draft" string="Brouillon" domain="[('state','=','draft')]" help="Fonctions en brouillon"/>
                <filter name="archived" string="Archivées" domain="[('state','=','archived')]" help="Fonctions archivées"/>
                <separator/>
                <filter name="group_by_state" string="Par statut" context="{'group_by':'state'}"/>
                <filter name="group_by_parent" string="Par parent" context="{'group_by':'parent_id'}"/>
                <filter name="group_by_manager" string="Par responsable" context="{'group_by':'manager_id'}"/>
            </search>
        </field>
    </record>

</odoo>