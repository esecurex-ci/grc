<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_risk_organization_list" model="ir.ui.view">
        <field name="name">risk.organization.list</field>
        <field name="model">risk.organization</field>
        <field name="arch" type="xml">
            <list multi_edit="1">
                <field name="code"/>
                <field name="name"/>
                <field name="manager_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_risk_organization_form" model="ir.ui.view">
        <field name="name">risk.organization.form</field>
        <field name="model">risk.organization</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="code"/>
                            <field name="manager_id"/>
                        </group>

                        <group>
                            <field name="active"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_risk_organization_search" model="ir.ui.view">
        <field name="name">risk.organization.search</field>
        <field name="model">risk.organization</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="name"/>
                <field name="manager_id"/>

            </search>
        </field>
    </record>

</odoo>