<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_risk_policy_form" model="ir.ui.view">
        <field name="name">risk.policy.form</field>
        <field name="model">risk.policy</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit_review" string="Soumettre pour revue" type="object"
                            invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_approve" string="Approuver" type="object" invisible="state != 'review'"
                            groups="base.group_erp_manager" class="oe_highlight"/>
                    <button name="action_publish" string="Publier" type="object" invisible="state != 'approved'"
                            class="oe_highlight"/>
                    <button name="action_archive" string="Archiver" type="object"
                            invisible="state not in ('published', 'approved')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,review,approved,published"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="code" readonly="1"/>
                        </h1>
                        <h2>
                            <field name="name" placeholder="Ex: Politique de sécurité de l'information"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="document_type"/>
                            <field name="version"/>
                            <field name="owner_id"/>
                            <field name="approver_id"/>
                        </group>
                        <group>
                            <field name="effective_date"/>
                            <field name="review_frequency"/>
                            <field name="next_review_date"/>
                            <field name="department_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Contenu">
                            <field name="content"/>
                        </page>
                        <page string="Liaisons GRC">
                            <group>
                                <field name="risk_ids" widget="many2many_tags"/>
                                <field name="control_ids" widget="many2many_tags"/>
                                <field name="regulation_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>
</odoo>