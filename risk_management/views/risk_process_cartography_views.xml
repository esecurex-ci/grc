<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================== -->
    <!-- VUE HIÉRARCHIQUE DES PROCESSUS                             -->
    <!-- ========================================================== -->

    <record id="view_risk_process_hierarchy" model="ir.ui.view">
        <field name="name">risk.process.hierarchy</field>
        <field name="model">risk.process</field>
        <field name="arch" type="xml">
            <list>
                <field name="code" string="Code"/>
                <field name="name" string="Processus"/>
                <field name="category" string="Catégorie"/>
                <field name="macro_process_id" string="Famille"/>
                <field name="owner_id" string="Propriétaire"/>
                <field name="count_risk" string="Risques" sum="Total"/>
                <field name="risk_level" widget="badge" string="Niveau"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ========================================================== -->
    <!-- VUE KANBAN DES PROCESSUS                                   -->
    <!-- ========================================================== -->

    <record id="view_risk_process_kanban" model="ir.ui.view">
        <field name="name">risk.process.kanban</field>
        <field name="model">risk.process</field>
        <field name="arch" type="xml">
            <kanban default_group_by="category" class="o_risk_process_kanban">
                <field name="name"/>
                <field name="code"/>
                <field name="category"/>
                <field name="macro_process_id"/>
                <field name="owner_id"/>
                <field name="risk_count"/>
                <field name="risk_level"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_risk_process_card"
                             t-attf-class="oe_kanban_global_click o_risk_process_card card-{{record.risk_level.raw_value || 'secondary'}}">

                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="code"/> - <field name="name"/>
                                </strong>
                                <div class="text-muted">
                                    <field name="category"/>
                                    <span> | </span>
                                    <field name="macro_process_id"/>
                                </div>
                                <div class="o_kanban_record_body">
                                    <span class="badge"
                                          t-attf-class="badge-{{record.risk_level.raw_value || 'secondary'}}">
                                        <field name="risk_level"/>
                                    </span>
                                    <span class="badge badge-secondary">
                                        <field name="count_risk"/> risques
                                    </span>
                                    <span class="text-muted">
                                        <i class="fa fa-user"/> <field name="owner_id"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

</odoo>