<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================== -->
    <!-- VUE HIÉRARCHIQUE DES PROCESSUS                             -->
    <!-- ========================================================== -->

    <record id="view_risk_process_hierarchy" model="ir.ui.view">
        <field name="name">risk.process.hierarchy</field>
        <field name="model">risk.process</field>
        <field name="arch" type="xml">
            <list>
                <field name="code" string="Code"/>
                <field name="name" string="Processus"/>
                <field name="category" string="Catégorie"/>
                <field name="macro_process_id" string="Famille"/>
                <field name="owner_id" string="Propriétaire"/>
                <field name="count_risk" string="Risques" sum="Total"/>
                <field name="risk_level" widget="badge" string="Niveau"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ========================================================== -->
    <!-- VUE KANBAN DES PROCESSUS                                   -->
    <!-- ========================================================== -->

    <record id="view_risk_process_kanban" model="ir.ui.view">
        <field name="name">risk.process.kanban</field>
        <field name="model">risk.process</field>
        <field name="arch" type="xml">
            <kanban default_group_by="category">
                <field name="name"/>
                <field name="code"/>
                <field name="category"/>
                <field name="macro_process_id"/>
                <field name="owner_id"/>
                <field name="count_risk"/>
                <field name="risk_level"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong>
                                    <field name="code"/> - <field name="name"/>
                                </strong>
                                <div>
                                    <field name="category"/>
                                    <field name="macro_process_id"/>
                                </div>
                                <div>
                                    <span class="badge">
                                        <field name="risk_level"/>
                                    </span>
                                    <span class="badge">
                                        <field name="count_risk"/> risques
                                    </span>
                                    <span>
                                        <field name="owner_id"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ========================================================== -->
    <!-- RECHERCHE - TRÈS ULTRA SIMPLE                              -->
    <!-- ========================================================== -->

    <record id="view_risk_process_search" model="ir.ui.view">
        <field name="name">risk.process.search</field>
        <field name="model">risk.process</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
            </search>
        </field>
    </record>

    <!-- ========================================================== -->
    <!-- VUE RAPPORT POUR LE CONSEIL                                -->
    <!-- ========================================================== -->

    <record id="view_risk_process_board_report" model="ir.ui.view">
        <field name="name">risk.process.board.report</field>
        <field name="model">risk.process</field>
        <field name="arch" type="xml">
            <list>
                <field name="code" string="Code"/>
                <field name="name" string="Processus"/>
                <field name="category" string="Catégorie"/>
                <field name="count_risk" string="Risques"/>
                <field name="risk_level" widget="badge" string="Niveau"/>
                <field name="owner_id" string="Propriétaire"/>
            </list>
        </field>
    </record>

</odoo>