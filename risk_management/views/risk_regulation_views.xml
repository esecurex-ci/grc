<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_risk_regulation_list" model="ir.ui.view">
        <field name="name">risk.regulation.list</field>
        <field name="model">risk.regulation</field>
        <field name="arch" type="xml">
            <list multi_edit="1">
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_risk_regulation_form" model="ir.ui.view">
        <field name="name">risk.regulation.form</field>
        <field name="model">risk.regulation</field>
        <field name="arch" type="xml">
            <form>

                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>

                        <group>
                            <field name="code"/>
                        </group>

                        <group>
                            <field name="active"/>
                        </group>

                    </group>

                    <notebook>

                        <page string="Description">
                            <field name="description"/>
                        </page>

                    </notebook>

                </sheet>

            </form>
        </field>
    </record>

    <record id="view_risk_regulation_search" model="ir.ui.view">
        <field name="name">risk.regulation.search</field>
        <field name="model">risk.regulation</field>
        <field name="arch" type="xml">
            <search>

                <field name="code"/>
                <field name="name"/>

                <filter name="active"
                        string="Actif"
                        domain="[('active','=',True)]"/>

            </search>
        </field>
    </record>

</odoo>