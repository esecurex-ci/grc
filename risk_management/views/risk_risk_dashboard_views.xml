<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================================================== -->
    <!-- VUE HEATMAP - CARTOGRAPHIE                                 -->
    <!-- ========================================================== -->

    <record id="view_risk_heatmap_graph" model="ir.ui.view">
        <field name="name">risk.heatmap.graph</field>
        <field name="model">risk.risk</field>
        <field name="arch" type="xml">
            <graph type="bar" stacked="True" string="🔥 Matrice des risques">
                <field name="inherent_impact" type="col"/>
                <field name="inherent_probability" type="row"/>
                <field name="inherent_score" type="measure"/>
            </graph>
        </field>
    </record>
