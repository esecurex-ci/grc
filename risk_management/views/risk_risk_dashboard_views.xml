    <!-- ========================================================== -->
    <!-- VUE KANBAN - DASHBOARD (SANS WIDGET)                      -->
    <!-- ========================================================== -->

    <record id="view_risk_dashboard_kanban" model="ir.ui.view">
        <field name="name">risk.dashboard.kanban</field>
        <field name="model">risk.risk</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="code"/>
                <field name="inherent_level"/>
                <field name="inherent_score"/>
                <field name="category_id"/>
                <field name="owner_id"/>
                <field name="state"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="code"/> - <field name="name"/>
                                </strong>
                                <div class="text-muted">
                                    <field name="category_id"/>
                                </div>
                                <div>
                                    <span class="badge">
                                        <field name="inherent_level"/>
                                    </span>
                                    <span class="badge">
                                        Score: <field name="inherent_score"/>
                                    </span>
                                    <span class="badge">
                                        <field name="state"/>
                                    </span>
                                </div>
                                <div>
                                    <i class="fa fa-user" title="Propriétaire"/>
                                    <field name="owner_id"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ========================================================== -->
    <!-- GRAPHIQUE - DASHBOARD                                      -->
    <!-- ========================================================== -->

    <record id="view_risk_dashboard_graph" model="ir.ui.view">
        <field name="name">risk.dashboard.graph</field>
        <field name="model">risk.risk</field>
        <field name="arch" type="xml">
            <graph type="bar" string="Distribution des risques par niveau">
                <field name="inherent_level" type="row"/>
                <field name="inherent_score" type="measure"/>
            </graph>
        </field>
    </record>


</odoo>