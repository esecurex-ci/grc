<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_risk_form" model="ir.ui.view">
        <field name="name">risk.risk.form</field>
        <field name="model">risk.risk</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form>
                <header>

                    <button name="action_assess"
                            string="Évaluer"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_close"
                            string="Fermer"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'validated'"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,validated,obsolete"/>
                </header>

                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="code" readonly="1"/>
                            <field name="name" placeholder="Nom du risque..."/>
                        </h1>
                    </div>


                    <group name="header_group">
                        <group name="left_group">
                            <field name="category_id" required="1"/>
                            <field name="subcategory_id"/>
                            <field name="risk_type"/>
                            <field name="risk_source"/>
                            <field name="owner_id" placeholder="Propriétaire du risque"/>
                        </group>

                        <group name="right_group">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="activity_id"/>
                            <field name="process_id"/>
                            <field name="macro_process_id"/>
                            <field name="active"/>
                            <field name="state"/>
                        </group>
                    </group>

                    <notebook>


                        <page string="Description" name="description">
                            <group style="min-width:40% !important;">
                                <field name="description" placeholder="Description du risque..."/>

                            </group>
                            <group style="min-width:40% !important;">
                                <field name="cause" placeholder="Cause..."/>
                            </group>
                            <group style="min-width:40% !important;">
                                <field name="consequence" placeholder="Conséquence..."/>
                                <field name="risk_event" placeholder="Événement redouté..."/>
                            </group>
                        </page>


                        <page string="📊 Matrice" name="matrix">
                            <group style="width:100% !important;overflow:auto;padding:10px;">

                                    <field name="matrix_html" nolabel="1"/>

                            </group>
                        </page>


                        <page string="Évaluation" name="evaluation">
                            <group name="evaluation_group" string="Évaluation du risque">
                                <group>
                                    <field name="inherent_probability"/>
                                    <field name="inherent_impact"/>
                                    <field name="inherent_score" readonly="1"/>
                                </group>
                                <group>
                                    <field name="residual_probability"/>
                                    <field name="residual_impact"/>
                                    <field name="residual_score" readonly="1"/>
                                    <field name="inherent_level" widget="badge"/>
                                </group>
                            </group>
                        </page>

                        <page string="📋 Documents">
                            <!-- ✅ CORRIGÉ : title ajouté -->
                            <div class="alert alert-info" style="margin-bottom:10px;" role="status">
                                <i class="fa fa-info-circle" title="Information"/>
                                <strong><field name="document_count"/></strong> document(s) de gouvernance lié(s) à ce risque
                            </div>
                            <!-- ✅ CORRIGÉ : active_id → id -->
                            <field name="document_ids" context="{'default_risk_ids': [(4, id)]}">
                                <list decoration-success="state == 'published'"
                                      decoration-info="state == 'approved'"
                                      decoration-warning="state in ('review', 'preparation')"
                                      decoration-danger="state in ('obsolete', 'archived')">
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="document_type" widget="badge"/>
                                    <field name="state" widget="badge"/>
                                    <field name="version_label"/>
                                    <field name="category_id"/>
                                    <field name="owner_id"/>
                                </list>
                            </field>
                        </page>

                        <page string="🔒 Contrôles" name="controls">
                            <group name="controls_group">
                                <field name="existing_control" nolabel="1" placeholder="Contrôles existants..."/>
                                <field name="control_ids" nolabel="1"/>
                            </group>
                        </page>


                        <page string="📈 KRI &amp; Compliance" name="kri">
                            <group name="kri_group">
                                <field name="kri_ids"/>
                                <field name="regulation_ids"/>
                                <field name="compliance_requirement_ids"/>
                            </group>
                        </page>


                        <page string="🏢 Actifs &amp; Organisation" name="assets">
                            <group name="assets_group">
                                <field name="asset_ids"/>
                                <field name="organization_ids"/>
                                <field name="cause_ids"/>
                                <field name="impact_ids"/>
                            </group>
                        </page>


                        <page string="⚠️ Incidents &amp; Audits" name="incidents">
                            <group name="incidents_group">
                                <field name="incident_count"/>
                                <field name="total_loss_amount"/>
                                <field name="incident_ids"/>
                                <field name="audit_finding_count"/>
                                <field name="audit_finding_ids"/>
                            </group>
                        </page>


                        <page string="📅 Révisions" name="review">
                            <group name="review_group">
                                <group name="dates_group" string="Calendrier">
                                    <field name="review_frequency"/>
                                    <field name="last_review_date"/>
                                    <field name="next_review_date" readonly="1"/>
                                    <field name="review_overdue" widget="boolean_toggle"/>
                                </group>
                            </group>
                        </page>


                        <page string="💬 Historique" name="history">
                            <chatter>
                                <field name="message_follower_ids"/>
                                <field name="activity_ids"/>
                                <field name="message_ids"/>
                           </chatter>
                        </page>

                        <!-- ✅ ONGLET DMR CORRIGÉ -->
                        <page string="🛡️ Dispositif de Maîtrise">
                            <!-- Synthèse DMR -->
                            <group string="📊 Synthèse du Dispositif de Maîtrise">
                                <div class="dmr-synthesis">
                                    <div class="dmr-card">
                                        <div class="dmr-label">Score de conformité</div>
                                        <div class="dmr-value score">
                                            <field name="dmr_compliance_score"/>%
                                        </div>
                                    </div>
                                    <div class="dmr-card">
                                        <div class="dmr-label">Niveau de maîtrise</div>
                                        <div class="dmr-value score">
                                            <field name="dmr_status" widget="badge"/>
                                        </div>
                                    </div>
                                    <div class="dmr-card">
                                        <div class="dmr-label">Contrôles efficaces</div>
                                        <div class="dmr-value controls">
                                            <field name="dmr_effective_control_count"/> / <field name="dmr_control_count"/>
                                        </div>
                                    </div>
                                    <div class="dmr-card">
                                        <div class="dmr-label">Actions en cours</div>
                                        <div class="dmr-value actions">
                                            <field name="dmr_action_count"/>
                                        </div>
                                    </div>
                                </div>
                            </group>

                            <!-- Détails des composants -->
                            <notebook>
                                <!-- 🔒 Contrôles -->
                                <!--page string="🔒 Contrôles">
                                    <div class="alert alert-info" role="status">
                                        <i class="fa fa-info-circle" title="Information"/>
                                        <strong><field name="dmr_control_count"/></strong> contrôle(s) associé(s)
                                        <span class="text-muted">- Efficacité: <field name="dmr_control_effectiveness_rate"/>%</span>
                                    </div>
                                    <field name="control_ids" context="{'default_risk_ids': [(4, id)]}">
                                        <list>
                                            <field name="code"/>
                                            <field name="name"/>
                                            <field name="control_type" widget="badge"/>
                                            <field name="effectiveness" widget="badge"/>
                                            <field name="test_success_rate" widget="progressbar"/>
                                            <field name="last_test_date"/>
                                        </list>
                                    </field>
                                </page-->

                                <page string="🔒 Contrôles" name="controls">
                                    <group name="controls_group">
                                        <field name="existing_control" nolabel="1" placeholder="Contrôles existants..."/>
                                        <field name="control_ids" nolabel="1"/>
                                    </group>
                                </page>

                                <!-- 📝 Tests -->
                                <page string="📝 Tests">
                                    <div class="alert alert-info" role="status">
                                        <i class="fa fa-info-circle" title="Information"/>
                                        <strong><field name="dmr_test_count"/></strong> test(s) effectué(s)
                                        <span class="text-muted">- Réussite: <field name="dmr_test_pass_rate"/>%</span>
                                    </div>
                                    <field name="test_ids" context="{'default_risk_ids': [(4, id)]}">
                                        <list decoration-success="result == 'pass'"
                                              decoration-warning="result == 'partial'"
                                              decoration-danger="result == 'fail'">
                                            <field name="code"/>
                                            <field name="name"/>
                                            <field name="test_date"/>
                                            <field name="tester_id"/>
                                            <field name="result" widget="badge"/>
                                            <field name="compliance_rate" widget="progressbar"/>
                                        </list>
                                    </field>
                                </page>

                                <!-- 🔧 Actions -->
                                <page string="🔧 Actions correctives">
                                    <div class="alert alert-info" role="status">
                                        <i class="fa fa-info-circle" title="Information"/>
                                        <strong><field name="dmr_action_count"/></strong> action(s)
                                        <span class="text-muted">- Progression: <field name="dmr_action_progress"/>%</span>
                                    </div>
                                    <field name="action_ids" context="{'default_risk_ids': [(4, id)]}">
                                        <list decoration-success="state == 'done'"
                                              decoration-warning="state == 'in_progress'"
                                              decoration-danger="state in ['overdue', 'cancelled']">
                                            <field name="code"/>
                                            <field name="name"/>
                                            <field name="state" widget="badge"/>
                                            <field name="deadline"/>
                                            <field name="owner_id"/>
                                            <field name="progress" widget="progressbar"/>
                                        </list>
                                    </field>
                                </page>

                                <!-- 📊 KRI -->
                                <page string="📊 KRI associés">
                                    <div class="alert alert-info" role="status">
                                        <i class="fa fa-info-circle" title="Information"/>
                                        <strong><field name="kri_ids"/></strong> KRI associé(s)
                                    </div>
                                    <field name="kri_ids" context="{'default_risk_ids': [(4, id)]}">
                                        <list decoration-success="status == 'green'"
                                              decoration-warning="status == 'amber'"
                                              decoration-danger="status == 'red'">
                                            <field name="code"/>
                                            <field name="name"/>
                                            <field name="current_value"/>
                                            <field name="unit"/>
                                            <field name="status" widget="badge"/>
                                            <field name="trend" widget="badge"/>
                                        </list>
                                    </field>
                                </page>
                            </notebook>
                        </page>

                    </notebook>
                </sheet>
            </form>

        </field>
    </record>

    <record id="view_risk_list" model="ir.ui.view">
        <field name="name">risk.list</field>
        <field name="model">risk.risk</field>
        <field name="arch" type="xml">
            <list
                decoration-success="inherent_level == 'low'"
                decoration-info="inherent_level == 'medium'"
                decoration-warning="inherent_level == 'high'"
                decoration-danger="inherent_level == 'critical'">
                <field name="code"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="inherent_score"/>
                <field name="residual_score"/>
                <field name="inherent_level" widget="badge"
                   class="badge"
                   decoration-success="inherent_level == 'low'"
                   decoration-info="inherent_level == 'medium'"
                   decoration-warning="inherent_level == 'high'"
                   decoration-danger="inherent_level == 'critical'"/>
                <field name="state" widget="badge"
                   class="badge"
                   decoration-success="state == 'validated'"
                   decoration-warning="state == 'draft'"
                   decoration-danger="state == 'obsolete'"/>
            </list>
        </field>
    </record>

</odoo>