<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================= -->
    <!-- VUE ARBRE - Tags                          -->
    <!-- ========================================= -->
    <record id="view_risk_tag_list" model="ir.ui.view">
        <field name="name">risk.tag.list</field>
        <field name="model">risk.tag</field>
        <field name="arch" type="xml">
            <list decoration-success="active == True" decoration-muted="active == False">
                <field name="name"/>
                <field name="code"/>
                <field name="category_id"/>
                <field name="color" widget="color"/>
                <field name="use_count" sum="Total"/>
                <field name="active" widget="boolean"/>
            </list>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- VUE FORMULAIRE - Tags                     -->
    <!-- ========================================= -->
    <record id="view_risk_tag_form" model="ir.ui.view">
        <field name="name">risk.tag.form</field>
        <field name="model">risk.tag</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_view_documents" string="📋 Voir les documents" type="object" 
                            class="btn-secondary" invisible="use_count == 0"/>
                    <!--
                    <button name="action_view_risks" string="🚨 Voir les risques" type="object" 
                            class="btn-secondary" invisible="use_count == 0"/>
                    -->
                    <button name="action_toggle_active" string="Activer/Désactiver" type="object" 
                            class="btn-secondary"/>
                    <field name="active" widget="boolean"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nom du tag..."/>
                        </h1>
                        <span class="oe_subtitle">
                            <field name="code" placeholder="Code"/>
                        </span>
                    </div>

                    <group>
                        <group>
                            <field name="category_id"/>
                            <field name="color" widget="color"/>
                            <field name="use_count" readonly="1"/>
                        </group>
                        <group>
                            <field name="active" widget="boolean"/>
                            <field name="description" placeholder="Description..."/>
                        </group>
                    </group>

                    <!-- ✅ CORRIGÉ : utilisation de invisible au lieu de attrs -->
                    <div class="alert alert-info" style="margin-top:10px;" invisible="use_count == 0" role="status">
                        <i class="fa fa-info-circle"/> Ce tag est utilisé <strong><field name="use_count"/></strong> fois.
                    </div>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- VUE RECHERCHE - Tags                      -->
    <!-- ========================================= -->
    <record id="view_risk_tag_search" model="ir.ui.view">
        <field name="name">risk.tag.search</field>
        <field name="model">risk.tag</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="category_id"/>
                <filter name="active" string="Actif" domain="[('active', '=', True)]"/>
                <filter name="has_use" string="Utilisé" domain="[('use_count', '>', 0)]"/>
                <filter name="no_use" string="Non utilisé" domain="[('use_count', '=', 0)]"/>
            </search>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- VUE ARBRE - Catégories de tags            -->
    <!-- ========================================= -->
    <record id="view_risk_tag_category_list" model="ir.ui.view">
        <field name="name">risk.tag.category.list</field>
        <field name="model">risk.tag.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="tag_count"/>
                <field name="active" widget="boolean"/>
            </list>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- VUE FORMULAIRE - Catégories de tags       -->
    <!-- ========================================= -->
    <record id="view_risk_tag_category_form" model="ir.ui.view">
        <field name="name">risk.tag.category.form</field>
        <field name="model">risk.tag.category</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_view_tags" string="📋 Voir les tags" type="object" 
                            class="btn-secondary" invisible="tag_count == 0"/>
                    <field name="active" widget="boolean"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nom de la catégorie..."/>
                        </h1>
                        <span class="oe_subtitle">
                            <field name="code" placeholder="Code"/>
                        </span>
                    </div>

                    <group>
                        <group>
                            <field name="tag_count" readonly="1"/>
                            <field name="active" widget="boolean"/>
                        </group>
                        <group>
                            <field name="description" placeholder="Description..."/>
                        </group>
                    </group>

                    <group string="Tags" invisible="tag_count == 0">
                        <field name="tag_ids" context="{'default_category_id': id}">
                            <list>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="use_count"/>
                                <field name="active" widget="boolean"/>
                            </list>
                        </field>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

</odoo>