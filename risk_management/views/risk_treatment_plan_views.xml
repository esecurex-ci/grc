<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================== -->
    <!-- LIST -->
    <!-- ===================================================== -->

    <record id="view_risk_treatment_plan_list" model="ir.ui.view">
        <field name="name">risk.treatment.plan.list</field>
        <field name="model">risk.treatment.plan</field>
        <field name="arch" type="xml">
            <list
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'in_progress'"
                  decoration-success="state == 'completed'"
                  decoration-danger="state == 'cancelled'">

                <field name="name"/>
                <field name="risk_id"/>
                <field name="owner_id"/>
                <field name="target_date"/>
                <field name="budget" widget="monetary"/>
                <field name="progress" widget="progressbar"/>
                <field name="state" widget="badge"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ===================================================== -->
    <!-- SEARCH -->
    <!-- ===================================================== -->

    <record id="view_risk_treatment_plan_search" model="ir.ui.view">
        <field name="name">risk.treatment.plan.search</field>
        <field name="model">risk.treatment.plan</field>
        <field name="arch" type="xml">
            <search>

                <field name="name"/>
                <field name="risk_id"/>
                <field name="owner_id"/>

                <separator/>

                <filter name="draft"
                        string="Brouillon"
                        domain="[('state','=','draft')]"/>

                <filter name="in_progress"
                        string="En cours"
                        domain="[('state','=','in_progress')]"/>

                <filter name="completed"
                        string="Terminé"
                        domain="[('state','=','completed')]"/>

                <filter name="cancelled"
                        string="Annulé"
                        domain="[('state','=','cancelled')]"/>

                <separator/>


            </search>
        </field>
    </record>

    <!-- ===================================================== -->
    <!-- FORM -->
    <!-- ===================================================== -->

    <record id="view_risk_treatment_plan_form" model="ir.ui.view">
        <field name="name">risk.treatment.plan.form</field>
        <field name="model">risk.treatment.plan</field>
        <field name="arch" type="xml">
            <form string="Plan de traitement">
                <header>
                    <button name="action_start"
                            string="Démarrer"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_complete"
                            string="Terminer"
                            type="object"
                            class="btn-success"
                            invisible="state != 'in_progress'"/>
                    <button name="action_cancel"
                            string="Annuler"
                            type="object"
                            class="btn-secondary"
                            invisible="state in ('completed','cancelled')"/>
                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nom du plan de traitement..."/>
                        </h1>
                    </div>

                    <group>
                        <group string="Informations générales">
                            <field name="assessment_id" required="1"/>
                            <field name="risk_id" readonly="1"/>
                            <field name="owner_id" placeholder="Fonction propriétaire"/>
                        </group>
                        <group string="Dates">
                            <field name="target_date" required="1"/>
                            <field name="completion_date" readonly="1"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>

                    <group string="Progression" colspan="2">
                        <field name="progress" widget="progressbar" nolabel="1"/>
                    </group>

                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Description du plan..." nolabel="1"/>
                        </page>
                        <page string="Budget">
                            <group>
                                <field name="budget" widget="monetary"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>

                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- ===================================================== -->
    <!-- KANBAN -->
    <!-- ===================================================== -->

    <record id="view_risk_treatment_plan_kanban" model="ir.ui.view">
        <field name="name">risk.treatment.plan.kanban</field>
        <field name="model">risk.treatment.plan</field>
        <field name="arch" type="xml">

            <kanban default_group_by="state">

                <field name="name"/>
                <field name="owner_id"/>
                <field name="target_date"/>
                <field name="progress"/>

                <templates>

                    <t t-name="card">

                        <div class="oe_kanban_global_click">

                            <div>
                                <strong>
                                    <field name="name"/>
                                </strong>
                            </div>

                            <div class="mt-2">
                                <field name="owner_id"/>
                            </div>

                            <div class="mt-2">
                                Echéance :
                                <field name="target_date"/>
                            </div>

                            <div class="mt-3">
                                <field name="progress"
                                       widget="progressbar"/>
                            </div>

                        </div>

                    </t>

                </templates>

            </kanban>

        </field>
    </record>

</odoo>